<Window x:Class="ArcelikExcelApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:ArcelikExcelApp.Converters"
        Title="Synctool - Maliyet Hesaplama Aracı" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI"
        Icon="/Assets/synctoolRed.png"
        Background="#F4F6FA"
        TextElement.Foreground="#333333">

    <Window.Resources>
        <converters:BooleanToReadBackgroundConverter x:Key="BooleanToReadBackgroundConverter"/>
        <converters:NotificationTypeToColorConverter x:Key="NotificationTypeToColorConverter"/>
        <converters:NotificationTypeToIconConverter x:Key="NotificationTypeToIconConverter"/>
        <converters:ParoluTextConverter x:Key="ParoluTextConverter"/>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Modern Sidebar Button Style -->
        <Style x:Key="PremiumNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A5B1"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="10,5,10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="12" Padding="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2D3E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E02020"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ScrollBar Style for Sidebar -->
        <Style x:Key="ModernSidebarScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false" />
            <Setter Property="Stylus.IsFlicksEnabled" Value="false" />
            <Setter Property="Width" Value="7" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="MinWidth" Value="7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder" 
                                                        Background="#666A7D" 
                                                        Opacity="0.3"
                                                        CornerRadius="3.5" 
                                                        Margin="1,0,1,0" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.7" />
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#A0A5B1" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.9" />
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#E02020" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1C1E2B" CornerRadius="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.1" Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header / Logo -->
                <Grid Grid.Row="0" Margin="10,40,10,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="45" Height="45" Background="#E02020" CornerRadius="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Viewbox Width="78" Height="78" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-10,0,0">
                            <Image Source="/Assets/synctoolAppIcon.png" RenderOptions.BitmapScalingMode="HighQuality" />
                        </Viewbox>
                    </Border>
                    <!-- Sadece genişken yazıyı göster -->
                    <TextBlock Grid.Column="1" Text="Synctool" FontSize="32" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"
                               Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                              materialDesign:ScrollViewerAssist.IsAutoHideEnabled="True">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ModernSidebarScrollBar}"/>
                    </ScrollViewer.Resources>
                    <StackPanel x:Name="MenuStackPanel" Margin="0,10,0,0">



                    <TextBlock Text="ANA MENÜ" Foreground="#666A7D" FontSize="12" FontWeight="SemiBold" Margin="25,0,0,15"
                               Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button x:Name="BtnDashboard" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Anasayfa" ToolTip="Dashboard">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ViewDashboard" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Dashboard" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Kea" ToolTip="Küçük Ev Aletleri">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Blender" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Küçük Ev Aletleri" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="BeyazEsya" ToolTip="Beyaz Eşya">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="186"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="WashingMachine" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Beyaz Eşya" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Tarihce" ToolTip="Eski Fiyat Arşivi">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="MoneyOff" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Eski Fiyatlar" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>


                    <Button x:Name="BtnExcelViewer" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="ExcelViewer" ToolTip="Excel Görüntüleyici">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="MicrosoftExcel" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Excel Görüntüleyici" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <StackPanel x:Name="AdminSection">
                        <TextBlock Text="İŞLEMLER" Foreground="#666A7D" FontSize="12" FontWeight="SemiBold" Margin="25,25,0,15"
                                   Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button x:Name="BtnManualCampaign" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="ManualCampaign" ToolTip="Kampanya Yönetimi">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="TagPlus" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Kampanya Yönetimi" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button x:Name="BtnCalculator" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="YeniFiyat" ToolTip="Maliyet Hesaplama">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="CalculatorVariant" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Maliyet Hesaplama" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button x:Name="BtnImportExcel" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Excell" ToolTip="Excel İçeri Aktar">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="DatabaseImport" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Excel İçeri Aktar" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button x:Name="BtnFileManagement" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="FileManagement" ToolTip="Dosya Yönetimi">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="FileCog" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Dosya Yönetimi" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button x:Name="BtnUserManagement" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="UserManagement" ToolTip="Kullanıcı Yönetimi">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="AccountGroup" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Kullanıcı Yönetimi" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="KULLANICI" Foreground="#666A7D" FontSize="12" FontWeight="SemiBold" Margin="25,25,0,15"
                               Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button x:Name="BtnSettingsSidebar" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Settings" ToolTip="Ayarlar">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="CogOutline" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Ayarlar" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>
                </StackPanel>
                </ScrollViewer>


                <!-- Footer Profile -->
                <Border Grid.Row="2" Margin="10,20,10,20" Background="#232635" CornerRadius="12" Padding="10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#3A3F55" HorizontalAlignment="Center" ToolTip="Profil">
                                <materialDesign:PackIcon Kind="AccountTie" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock x:Name="TxtUsername" Text="Yönetici" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtRole" Text="Admin" Foreground="#4CAF50" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                    Width="30" Height="30" Background="Transparent" BorderBrush="Transparent"
                                    Click="BtnLogout_Click" ToolTip="Çıkış Yap"
                                    Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <materialDesign:PackIcon Kind="Logout" Foreground="#EF5350" Width="18" Height="18"/>
                            </Button>
                        </Grid>
                        <TextBlock x:Name="TxtAppVersion" Text="v1.0.8" Foreground="#666A7D" FontSize="11" HorizontalAlignment="Center" Margin="0,15,0,0"
                                   Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Topbar -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ToggleButton x:Name="MenuToggleButton" Grid.Column="0"
                              Style="{StaticResource MaterialDesignHamburgerToggleButton}" 
                              IsChecked="True" 
                              Margin="0,0,20,0"
                              Click="MenuToggleButton_Click"/>

                <TextBlock Grid.Column="1" x:Name="TxtPageTitle" Text="Dashboard" FontSize="32" FontWeight="Bold" Foreground="#1A1A24" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Modern Cart Icon with Badge -->
                    <materialDesign:Badged x:Name="BadgeCart" Badge="0" BadgeBackground="#E02020" BadgeForeground="White" Margin="0,0,15,0">
                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                Background="White" BorderBrush="Transparent" Click="BtnCart_Click">
                            <materialDesign:PackIcon Kind="CartOutline" Foreground="#666A7D" Width="20" Height="20"/>
                        </Button>
                    </materialDesign:Badged>

                    <!-- Modern Notification Bell with Badge -->
                    <materialDesign:Badged x:Name="BadgeNotifications" Badge="0" BadgeBackground="Red" BadgeForeground="White" Margin="0,0,15,0">
                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                Background="White" BorderBrush="Transparent" Click="BtnNotifications_Click">
                            <materialDesign:PackIcon Kind="BellOutline" Foreground="#666A7D" Width="20" Height="20"/>
                        </Button>
                    </materialDesign:Badged>

                    <!-- Cart Popup Panel -->
                    <Popup x:Name="PopupCart" AllowsTransparency="True" StaysOpen="False" 
                           Placement="Bottom" PlacementTarget="{Binding ElementName=BadgeCart}"
                           PopupAnimation="Fade" VerticalOffset="12" HorizontalOffset="-20">
                        <materialDesign:Card Width="400" MaxHeight="580" UniformCornerRadius="20" Background="White" 
                                           materialDesign:ElevationAssist.Elevation="Dp16" Margin="0,0,25,25">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0" Padding="24,20,24,16" Background="Transparent" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="ShoppingOutline" Width="24" Height="24" Foreground="#1E293B" Margin="0,0,10,0"/>
                                            <TextBlock Text="Sepetim" FontSize="20" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right" Content="Temizle" 
                                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#EF4444" 
                                                FontSize="13" FontWeight="SemiBold" Padding="12,0" Height="32" Click="BtnClearCart_Click"/>
                                    </Grid>
                                </Border>

                                <!-- Items List -->
                                <ScrollViewer Grid.Row="1" MaxHeight="360" VerticalScrollBarVisibility="Auto" Padding="0,5">
                                    <ItemsControl x:Name="ItemsCart">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="24,18" Background="Transparent" BorderBrush="#F8FAFC" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Product Icon -->
                                                        <Border Width="48" Height="48" CornerRadius="14" Background="#F1F5F9" VerticalAlignment="Top">
                                                            <materialDesign:PackIcon Kind="PackageVariant" Foreground="#64748B"
                                                                                     Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Product Details -->
                                                        <StackPanel Grid.Column="1" Margin="16,0,10,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="15" Foreground="#1E293B" TextWrapping="Wrap" LineHeight="20"/>
                                                            <TextBlock Text="{Binding ProductCode}" FontSize="13" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                                            
                                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding SelectedPrice, StringFormat={}{0:N2} ₺}" FontWeight="ExtraBold" Foreground="#E02020" FontSize="16"/>
                                                                <Border Background="#EFF6FF" CornerRadius="6" Margin="10,0,0,0" Padding="8,3" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding IsParolu, Converter={StaticResource ParoluTextConverter}}" FontSize="11" Foreground="#3B82F6" FontWeight="Bold"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Remove Button -->
                                                        <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconForegroundButton}" 
                                                                Width="32" Height="32" Padding="0" VerticalAlignment="Top" HorizontalAlignment="Right"
                                                                Click="BtnRemoveFromCart_Click" Tag="{Binding Id}" ToolTip="Sepetten Çıkar"
                                                                Foreground="#CBD5E1">
                                                            <materialDesign:PackIcon Kind="CloseThick" Width="16" Height="16"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Footer -->
                                <Border Grid.Row="2" Padding="24" Background="#F8FAFC" CornerRadius="0,0,20,20">
                                    <StackPanel>
                                        <!-- Ara Toplam -->
                                        <Grid Margin="0,0,0,10">
                                            <TextBlock Text="Ara Toplam" FontSize="14" Foreground="#64748B" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCartSubTotal" Text="0,00 ₺" HorizontalAlignment="Right" FontSize="16" FontWeight="SemiBold" Foreground="#475569"/>
                                        </Grid>
                                        
                                        <!-- İndirim Girişi -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="İndirim (₺):" FontSize="14" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox x:Name="TxtCartDiscount" Grid.Column="2" 
                                                     materialDesign:HintAssist.Hint="0,00" 
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     HorizontalContentAlignment="Right"
                                                     Padding="8,5" Height="32"
                                                     TextChanged="TxtCartDiscount_TextChanged"/>
                                        </Grid>

                                        <Border BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Margin="0,0,0,16"/>

                                        <!-- Genel Toplam (Nakit) -->
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock Text="Genel Toplam (Nakit)" FontSize="15" FontWeight="Medium" Foreground="#64748B" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCartTotal" Text="0,00 ₺" HorizontalAlignment="Right" FontSize="20" FontWeight="Black" Foreground="#0F172A"/>
                                        </Grid>

                                        <!-- Genel Toplam (Kart) -->
                                        <Grid>
                                            <TextBlock Text="Genel Toplam (Kart)" FontSize="15" FontWeight="Medium" Foreground="#64748B" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCartTotalCard" Text="0,00 ₺" HorizontalAlignment="Right" FontSize="20" FontWeight="Black" Foreground="#E02020"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </materialDesign:Card>
                    </Popup>


                    <!-- Notification Popup Panel -->
                    <Popup x:Name="PopupNotifications" AllowsTransparency="True" StaysOpen="False" 
                           Placement="Bottom" PlacementTarget="{Binding ElementName=BadgeNotifications}"
                           PopupAnimation="Slide" VerticalOffset="10">
                        <materialDesign:Card Width="380" MaxHeight="500" UniformCornerRadius="18" Background="White" 
                                           materialDesign:ElevationAssist.Elevation="Dp12" Margin="0,0,15,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="20,15" Background="#F8F9FB" CornerRadius="18,18,0,0">
                                    <Grid>
                                        <TextBlock Text="Bildirimler" FontSize="18" FontWeight="Bold" Foreground="#1A1A24" VerticalAlignment="Center"/>
                                        <Button HorizontalAlignment="Right" Content="Tümünü Okundu Say" 
                                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#3949AB" 
                                                FontSize="12" Click="BtnMarkAllRead_Click"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" MaxHeight="350" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ItemsNotifications">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="Auto" 
                                                        HorizontalContentAlignment="Stretch" Click="BtnNotificationDetail_Click" Tag="{Binding Id}">
                                                    <Border Padding="20,15" BorderBrush="#F1F3F9" BorderThickness="0,0,0,1" 
                                                            Background="{Binding IsRead, Converter={StaticResource BooleanToReadBackgroundConverter}}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="40" Height="40" CornerRadius="12" 
                                                                    Background="{Binding Type, Converter={StaticResource NotificationTypeToColorConverter}, ConverterParameter=Light}">
                                                                <materialDesign:PackIcon Kind="{Binding Type, Converter={StaticResource NotificationTypeToIconConverter}}" 
                                                                                         Foreground="{Binding Type, Converter={StaticResource NotificationTypeToColorConverter}}"
                                                                                         Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="#1A1A24"/>
                                                                <TextBlock Text="{Binding Message}" FontSize="13" Foreground="#7E84A3" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd MMM HH:mm}}" FontSize="11" Foreground="#BDBDBD" Margin="0,5,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Row="2" Padding="15" Background="White" CornerRadius="0,0,18,18" BorderBrush="#F1F3F9" BorderThickness="0,1,0,0">
                                    <Button Content="Tüm Bildirimleri Gör" Style="{StaticResource MaterialDesignFlatButton}" 
                                            HorizontalAlignment="Center" Foreground="#E02020" FontWeight="Bold" Click="BtnViewAllNotifications_Click"/>
                                </Border>
                            </Grid>
                        </materialDesign:Card>
                    </Popup>
                </StackPanel>
            </Grid>

            <!-- Dynamic Content Control with Shadow -->
            <Border Grid.Row="1" Background="White" CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect Color="#888888" BlurRadius="25" Opacity="0.08" Direction="270" ShadowDepth="5"/>
                </Border.Effect>

                <ContentControl x:Name="MainContentControl" Margin="20"/>
            </Border>

            <!-- Premium Toast Overlay (Bottom Right) -->
            <Grid x:Name="ToastOverlay" Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,30,40" Opacity="0" IsHitTestVisible="False">
                <materialDesign:Card UniformCornerRadius="15" Background="#1A1A24" Padding="20,15" materialDesign:ElevationAssist.Elevation="Dp8">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.4" ShadowDepth="4"/>
                    </materialDesign:Card.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" Background="#10B981" CornerRadius="16" Margin="0,0,15,0">
                            <materialDesign:PackIcon Kind="Check" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                        </Border>
                        <TextBlock x:Name="TxtToastMessage" Text="Ürün sepete eklendi" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ToastTranslate" Y="40"/>
                </Grid.RenderTransform>
            </Grid>
        </Grid>
        <!-- Global Modern Dialog Overlay -->
        <Grid x:Name="ModernDialogOverlay" Grid.ColumnSpan="2" Visibility="Collapsed">
            <Border Background="#111A1A24">
                <Border.Effect>
                    <BlurEffect Radius="15"/>
                </Border.Effect>
            </Border>
            <Grid Background="#22FFFFFF">
                <materialDesign:Card Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="25" Background="White">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.2" Direction="270" ShadowDepth="10"/>
                    </materialDesign:Card.Effect>
                    <Border Padding="35">
                        <StackPanel>
                            <Border x:Name="BorderDialogIcon" Width="60" Height="60" Background="#E3F2FD" CornerRadius="30" Margin="0,0,0,20">
                                <materialDesign:PackIcon x:Name="IconDialog" Kind="Information" Width="30" Height="30" Foreground="#2196F3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="TxtDialogTitle" Text="Başlık" FontSize="22" FontWeight="Bold" 
                                       Foreground="#1A1A24" Margin="0,0,0,10" HorizontalAlignment="Center" TextAlignment="Center"/>

                            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" Margin="0,0,0,30">
                                <TextBlock x:Name="TxtDialogMessage" Text="Mesaj içeriği..." FontSize="15" 
                                           Foreground="#666A7D" TextWrapping="Wrap" LineHeight="22" TextAlignment="Center"/>
                            </ScrollViewer>

                            <Grid x:Name="GridDialogButtons">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnDialogCancel" Grid.Column="0" Content="İptal" Style="{StaticResource MaterialDesignFlatButton}" 
                                        Foreground="#7E84A3" Height="48" Margin="0,0,5,0" Click="BtnDialogResult_Click" Tag="False"/>

                                <Button x:Name="BtnDialogConfirm" Grid.Column="1" Content="Tamam" Foreground="White" Background="#1A1A24" BorderBrush="#1A1A24" 
                                        materialDesign:ButtonAssist.CornerRadius="14" Height="48" FontWeight="SemiBold"
                                        Click="BtnDialogResult_Click" Tag="True"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</Window>