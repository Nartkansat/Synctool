<Window x:Class="ArcelikExcelApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:ArcelikExcelApp.Converters"
        Title="Synctool - Maliyet Hesaplama Aracı" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        WindowState="Maximized"
        FontFamily="Segoe UI"
        Icon="/Assets/synctoolRed.png"
        Background="#F4F6FA"
        TextElement.Foreground="#333333">

    <Window.Resources>
        <converters:BooleanToReadBackgroundConverter x:Key="BooleanToReadBackgroundConverter"/>
        <converters:NotificationTypeToColorConverter x:Key="NotificationTypeToColorConverter"/>
        <converters:NotificationTypeToIconConverter x:Key="NotificationTypeToIconConverter"/>
        <converters:ParoluTextConverter x:Key="ParoluTextConverter"/>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Modern Sidebar Button Style -->
        <Style x:Key="PremiumNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8890A4"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="8,8,8,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                    CornerRadius="10" Padding="0">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Sol Accent Bar -->
                            <Rectangle x:Name="LeftBar" Width="3" HorizontalAlignment="Left"
                                       Fill="{TemplateBinding BorderBrush}"
                                       RadiusX="1.5" RadiusY="1.5" Margin="0,7,0,7"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1C1F35"/>
                                <Setter Property="Foreground" Value="#B0B8CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#22263D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Global Premium ScrollBar Style -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false" />
            <Setter Property="Stylus.IsFlicksEnabled" Value="false" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="MinWidth" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder" 
                                                        Background="#B0B8CC" 
                                                        Opacity="0.4"
                                                        CornerRadius="4" 
                                                        Margin="1,2" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.7" />
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#64748B" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="1.0" />
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#E02020" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Floating Edge Toggle Button - Sidebar kenar tutamacı -->
        <ToggleButton x:Name="MenuToggleButton"
                      Grid.Column="0"
                      Panel.ZIndex="100"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,82,-13,0"
                      Width="26" Height="26"
                      IsChecked="True"
                      Click="MenuToggleButton_Click"
                      Cursor="Hand"
                      ToolTip="Menüyü Aç/Kapat">
            <ToggleButton.Style>
                <Style TargetType="ToggleButton">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bg"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="13"
                                        BorderBrush="#DDE1EC"
                                        BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.12" Direction="270" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <materialDesign:PackIcon x:Name="Icon"
                                                             Kind="ChevronLeft"
                                                             Width="15" Height="15"
                                                             Foreground="#64748B"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#F1F5F9"/>
                                        <Setter TargetName="Icon" Property="Foreground" Value="#1A1A24"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter TargetName="Icon" Property="Kind" Value="ChevronRight"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ToggleButton.Style>
        </ToggleButton>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#191B2A" CornerRadius="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="24" Opacity="0.18" Direction="0"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header / Logo -->
                <Grid Grid.Row="0" Margin="8,26,8,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="44" Height="44" Background="#E02020" CornerRadius="7" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Viewbox Width="68" Height="65" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-4,0,0">
                            <Image Source="/Assets/synctoolAppIcon.png" RenderOptions.BitmapScalingMode="HighQuality" />
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0"
                                Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Synctool" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Maliyet Aracı" FontSize="12" Foreground="#4A5070"/>
                    </StackPanel>
                </Grid>

                <!-- Divider -->
                <Border Grid.Row="0" Height="1" Background="#23263A" VerticalAlignment="Bottom" Margin="10,0,10,0"/>

                <!-- Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                              materialDesign:ScrollViewerAssist.IsAutoHideEnabled="True">
                    <StackPanel x:Name="MenuStackPanel" Margin="0,4,0,4">

                    <TextBlock Text="ANA MENÜ" Foreground="#3D4166" FontSize="11" FontWeight="Bold" Margin="15,10,0,6"
                               Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button x:Name="BtnDashboard" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Anasayfa" ToolTip="Dashboard">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ViewDashboard" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Dashboard" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Kea" ToolTip="Küçük Ev Aletleri">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="Blender" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Küçük Ev Aletleri" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="BeyazEsya" ToolTip="Beyaz Eşya">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="WashingMachine" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Beyaz Eşya" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Tarihce" ToolTip="Eski Fiyat Arşivi">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="MoneyOff" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Eski Fiyatlar" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <Button x:Name="BtnExcelViewer" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="ExcelViewer" ToolTip="Excel Görüntüleyici">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="MicrosoftExcel" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Excel Görüntüleyici" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>

                    <StackPanel x:Name="AdminSection">
                        <TextBlock Text="İŞLEMLER" Foreground="#3D4166" FontSize="11" FontWeight="Bold" Margin="15,10,0,6"
                                   Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button x:Name="BtnManualCampaign" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="ManualCampaign" ToolTip="Kampanya Yönetimi">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="TagPlus" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Kampanya Yönetimi" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button x:Name="BtnCalculator" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="YeniFiyat" ToolTip="Maliyet Hesaplama">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="CalculatorVariant" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Maliyet Hesaplama" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button x:Name="BtnImportExcel" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Excell" ToolTip="Excel İçeri Aktar">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="DatabaseImport" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Excel İçeri Aktar" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button x:Name="BtnFileManagement" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="FileManagement" ToolTip="Dosya Yönetimi">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="FileCog" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Dosya Yönetimi" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button x:Name="BtnUserManagement" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="UserManagement" ToolTip="Kullanıcı Yönetimi">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="AccountGroup" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Kullanıcı Yönetimi" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                           Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="KULLANICI" Foreground="#3D4166" FontSize="11" FontWeight="Bold" Margin="15,10,0,6"
                               Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Bildirimler -->
                    <Button x:Name="BtnSidebarNotifications" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Notifications" ToolTip="Bildirimler">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Sadece Icon -->
                            <Grid Grid.Column="0" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="BellOutline" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                        Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Bildirimler" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"/>
                                <Border x:Name="SidebarNotifBadgeExpanded" Background="#E02020" CornerRadius="12" Margin="10,0,0,0" Padding="7,4"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="TxtSidebarNotifBadgeExpanded" Text="0" FontSize="10" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="BtnSettingsSidebar" Style="{StaticResource PremiumNavButton}" Click="Nav_Click" Tag="Settings" ToolTip="Ayarlar">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="46"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="CogOutline" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Ayarlar" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"
                                       Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Button>
                </StackPanel>
                </ScrollViewer>


                <!-- Footer Profile -->
                <Border Grid.Row="2" Margin="8,8,8,10" Background="#1E2136" CornerRadius="10" Padding="8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15" Background="#2E3250" HorizontalAlignment="Center" ToolTip="Profil">
                                <materialDesign:PackIcon Kind="AccountTie" Width="18" Height="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock x:Name="TxtUsername" Text="Yönetici" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtRole" Text="Admin" Foreground="#4CAF50" FontSize="11"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}"
                                    Width="26" Height="26" Background="Transparent" BorderBrush="Transparent"
                                    Click="BtnLogout_Click" ToolTip="Çıkış Yap"
                                    Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <materialDesign:PackIcon Kind="Logout" Foreground="#EF5350" Width="15" Height="15"/>
                            </Button>
                        </Grid>
                        <TextBlock x:Name="TxtAppVersion" Text="v1.0.8" Foreground="#3D4166" FontSize="10" HorizontalAlignment="Center" Margin="0,8,0,0"
                                   Visibility="{Binding IsChecked, ElementName=MenuToggleButton, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Topbar -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Page Title Area -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Page Icon -->
                    <Border x:Name="BorderPageIcon" Width="42" Height="42" CornerRadius="12"
                            Background="#F0F1F8" Margin="0,0,14,0" VerticalAlignment="Center">
                        <materialDesign:PackIcon x:Name="IconPageTitle" Kind="ViewDashboard"
                                                 Width="22" Height="22" Foreground="#4F46E5"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- Title + Subtitle -->
                    <StackPanel VerticalAlignment="Center" Margin="0,0,0,2">
                        <TextBlock x:Name="TxtPageTitle" Text="Dashboard"
                                   FontSize="22" FontWeight="Bold" Foreground="#1A1A24"
                                   LineHeight="26"/>
                        <TextBlock x:Name="TxtPageSubtitle" Text="Genel istatistikler ve sistem özeti"
                                   FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Modern Cart Icon with Badge -->
                    <materialDesign:Badged x:Name="BadgeCart" Badge="0" BadgeBackground="#E02020" BadgeForeground="White" Margin="0,0,15,0">
                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                Background="White" BorderBrush="Transparent" Click="BtnCart_Click">
                            <materialDesign:PackIcon Kind="CartOutline" Foreground="#666A7D" Width="20" Height="20"/>
                        </Button>
                    </materialDesign:Badged>

                    <!-- Modern Notification Bell with Badge -->
                    <materialDesign:Badged x:Name="BadgeNotifications" Badge="0" BadgeBackground="Red" BadgeForeground="White" Margin="0,0,15,0">
                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                Background="White" BorderBrush="Transparent" Click="BtnNotifications_Click">
                            <materialDesign:PackIcon Kind="BellOutline" Foreground="#666A7D" Width="20" Height="20"/>
                        </Button>
                    </materialDesign:Badged>

                    <!-- Cart Popup Panel -->
                    <Popup x:Name="PopupCart" AllowsTransparency="True" StaysOpen="False" 
                           Placement="Bottom" PlacementTarget="{Binding ElementName=BadgeCart}"
                           PopupAnimation="Fade" VerticalOffset="15" HorizontalOffset="0">
                        <Border Width="420" MaxHeight="600" Background="White" CornerRadius="24" Margin="20">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="35" Opacity="0.12" Direction="270" ShadowDepth="5"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0" Padding="24,20" Background="#F8FAFC" CornerRadius="24,24,0,0" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="36" Height="36" CornerRadius="10" Background="#EEF2FF" Margin="0,0,12,0">
                                                <materialDesign:PackIcon Kind="ShoppingOutline" Width="20" Height="20" Foreground="#4F46E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Sepetim" FontSize="18" FontWeight="ExtraBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right" Click="BtnClearCart_Click"
                                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#EF4444" 
                                                Padding="12,0" Height="32" materialDesign:ButtonAssist.CornerRadius="8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="DeleteSweepOutline" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Temizle" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Items List -->
                                <ScrollViewer Grid.Row="1" MaxHeight="340" VerticalScrollBarVisibility="Auto" Padding="0">
                                    <ItemsControl x:Name="ItemsCart">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="ItemBorder" Padding="24,16" Background="Transparent" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Product Icon -->
                                                        <Border Width="52" Height="52" CornerRadius="16" Background="#F1F5F9" VerticalAlignment="Top">
                                                            <materialDesign:PackIcon Kind="PackageVariantClosed" Foreground="#64748B"
                                                                                     Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- Product Details -->
                                                        <StackPanel Grid.Column="1" Margin="16,0,10,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="14" Foreground="#1E293B" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding ProductCode}" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0" FontFamily="Consolas"/>
                                                            
                                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding SelectedPrice, StringFormat={}{0:N2} ₺}" FontWeight="ExtraBold" Foreground="#E02020" FontSize="15"/>
                                                                <Border Background="#F0F9FF" CornerRadius="6" Margin="10,0,0,0" Padding="8,3" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding IsParolu, Converter={StaticResource ParoluTextConverter}}" FontSize="10" Foreground="#0369A1" FontWeight="Bold"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Remove Button -->
                                                        <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}" 
                                                                Width="32" Height="32" VerticalAlignment="Center"
                                                                Click="BtnRemoveFromCart_Click" Tag="{Binding Id}" ToolTip="Sepetten Çıkar"
                                                                Foreground="#CBD5E1">
                                                            <materialDesign:PackIcon Kind="CloseCircle" Width="18" Height="18"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#FAFBFF"/>
                                                    </Trigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Footer -->
                                <Border Grid.Row="2" Padding="24" Background="White" CornerRadius="0,0,24,24" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0">
                                    <StackPanel>
                                        <!-- Ara Toplam -->
                                        <Grid Margin="0,0,0,12">
                                            <TextBlock Text="Ara Toplam" FontSize="13" Foreground="#94A3B8" FontWeight="Medium" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCartSubTotal" Text="0,00 ₺" HorizontalAlignment="Right" FontSize="15" FontWeight="Bold" Foreground="#64748B"/>
                                        </Grid>
                                        
                                        <!-- İndirim Girişi (Modern & Professional) -->
                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="36" Height="36" Background="#F1F5F9" CornerRadius="10" Margin="0,0,12,0">
                                                    <materialDesign:PackIcon Kind="TagOutline" Width="18" Height="18" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="Özel İndirim" FontSize="13" Foreground="#1E293B" FontWeight="Bold"/>
                                                    <TextBlock Text="Tutar bazlı indirim uygula" FontSize="10" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="12,4" Width="130" Height="40">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="TxtCartDiscount" 
                                                             BorderThickness="0" 
                                                             Background="Transparent"
                                                             HorizontalContentAlignment="Right"
                                                             VerticalContentAlignment="Center"
                                                             FontSize="15" FontWeight="ExtraBold"
                                                             Foreground="#1E293B"
                                                             materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                                             materialDesign:HintAssist.Hint="0,00"
                                                             TextChanged="TxtCartDiscount_TextChanged"/>
                                                    <TextBlock Grid.Column="1" Text="₺" FontSize="13" Foreground="#94A3B8" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <Border Height="1" Background="#F1F5F9" Margin="0,0,0,16"/>

                                        <!-- Toplamlar -->
                                        <!--<Grid Margin="0,0,0,8">
                                            <TextBlock Text="Genel Toplam (Nakit)" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtCartTotal" Text="0,00 ₺" HorizontalAlignment="Right" FontSize="20" FontWeight="ExtraBold" Foreground="#1E293B"/>
                                        </Grid>-->

                                        <Border Background="#ECFDF5" CornerRadius="12" Padding="16,12" Margin="0,8,0,0">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Money" Width="18" Height="18" Foreground="#10B981" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Genel Toplam (Nakit)" FontSize="14" FontWeight="Bold"  Foreground="#10B981" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="TxtCartTotal" Text="0,00 ₺" HorizontalAlignment="Right" FontSize="18" FontWeight="ExtraBold" Foreground="#10B981"/>
                                            </Grid>
                                        </Border>

                                        <Border Background="#FFF1F2" CornerRadius="12" Padding="16,12" Margin="0,8,0,0">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CreditCardOutline" Width="18" Height="18" Foreground="#E02020" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Kart Toplamı" FontSize="14" FontWeight="Bold" Foreground="#E02020" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="TxtCartTotalCard" Text="0,00 ₺" HorizontalAlignment="Right" FontSize="18" FontWeight="ExtraBold" Foreground="#E02020"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>


                    <!-- Notification Popup Panel -->
                    <Popup x:Name="PopupNotifications" AllowsTransparency="True" StaysOpen="False" 
                           Placement="Bottom" PlacementTarget="{Binding ElementName=BadgeNotifications}"
                           PopupAnimation="Slide" VerticalOffset="10">
                        <materialDesign:Card Width="380" MaxHeight="500" UniformCornerRadius="18" Background="White" 
                                           materialDesign:ElevationAssist.Elevation="Dp12" Margin="0,0,15,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Padding="20,15" Background="#F8F9FB" CornerRadius="18,18,0,0">
                                    <Grid>
                                        <TextBlock Text="Bildirimler" FontSize="18" FontWeight="Bold" Foreground="#1A1A24" VerticalAlignment="Center"/>
                                        <Button HorizontalAlignment="Right" Content="Tümünü Okundu Say" 
                                                Style="{StaticResource MaterialDesignFlatButton}" Foreground="#3949AB" 
                                                FontSize="12" Click="BtnMarkAllRead_Click"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" MaxHeight="350" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ItemsNotifications">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Height="Auto" 
                                                        HorizontalContentAlignment="Stretch" Click="BtnNotificationDetail_Click" Tag="{Binding Id}">
                                                    <Border Padding="20,15" BorderBrush="#F1F3F9" BorderThickness="0,0,0,1" 
                                                            Background="{Binding IsRead, Converter={StaticResource BooleanToReadBackgroundConverter}}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="40" Height="40" CornerRadius="12" 
                                                                    Background="{Binding Type, Converter={StaticResource NotificationTypeToColorConverter}, ConverterParameter=Light}">
                                                                <materialDesign:PackIcon Kind="{Binding Type, Converter={StaticResource NotificationTypeToIconConverter}}" 
                                                                                         Foreground="{Binding Type, Converter={StaticResource NotificationTypeToColorConverter}}"
                                                                                         Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="#1A1A24"/>
                                                                <TextBlock Text="{Binding Message}" FontSize="13" Foreground="#7E84A3" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd MMM HH:mm}}" FontSize="11" Foreground="#BDBDBD" Margin="0,5,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Row="2" Padding="15" Background="White" CornerRadius="0,0,18,18" BorderBrush="#F1F3F9" BorderThickness="0,1,0,0">
                                    <Button Content="Tüm Bildirimleri Gör" Style="{StaticResource MaterialDesignFlatButton}" 
                                            HorizontalAlignment="Center" Foreground="#E02020" FontWeight="Bold" Click="BtnViewAllNotifications_Click"/>
                                </Border>
                            </Grid>
                        </materialDesign:Card>
                    </Popup>
                </StackPanel>
            </Grid>

            <!-- Dynamic Content Control with Shadow -->
            <Border Grid.Row="1" Background="White" CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect Color="#888888" BlurRadius="25" Opacity="0.08" Direction="270" ShadowDepth="5"/>
                </Border.Effect>

                <ContentControl x:Name="MainContentControl" Margin="20"/>
            </Border>

            <!-- Premium Toast Overlay (Bottom Right) -->
            <Grid x:Name="ToastOverlay" Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,30,40" Opacity="0" IsHitTestVisible="False">
                <materialDesign:Card UniformCornerRadius="15" Background="#1A1A24" Padding="20,15" materialDesign:ElevationAssist.Elevation="Dp8">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.4" ShadowDepth="4"/>
                    </materialDesign:Card.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" Background="#10B981" CornerRadius="16" Margin="0,0,15,0">
                            <materialDesign:PackIcon Kind="Check" Foreground="White" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                        </Border>
                        <TextBlock x:Name="TxtToastMessage" Text="Ürün sepete eklendi" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ToastTranslate" Y="40"/>
                </Grid.RenderTransform>
            </Grid>
        </Grid>
        <!-- Global Modern Dialog Overlay -->
        <Grid x:Name="ModernDialogOverlay" Grid.ColumnSpan="2" Visibility="Collapsed">
            <Border Background="#111A1A24">
                <Border.Effect>
                    <BlurEffect Radius="15"/>
                </Border.Effect>
            </Border>
            <Grid Background="#22FFFFFF">
                <materialDesign:Card Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="25" Background="White">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.2" Direction="270" ShadowDepth="10"/>
                    </materialDesign:Card.Effect>
                    <Border Padding="35">
                        <StackPanel>
                            <Border x:Name="BorderDialogIcon" Width="60" Height="60" Background="#E3F2FD" CornerRadius="30" Margin="0,0,0,20">
                                <materialDesign:PackIcon x:Name="IconDialog" Kind="Information" Width="30" Height="30" Foreground="#2196F3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="TxtDialogTitle" Text="Başlık" FontSize="22" FontWeight="Bold" 
                                       Foreground="#1A1A24" Margin="0,0,0,10" HorizontalAlignment="Center" TextAlignment="Center"/>

                            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto" Margin="0,0,0,30">
                                <TextBlock x:Name="TxtDialogMessage" Text="Mesaj içeriği..." FontSize="15" 
                                           Foreground="#666A7D" TextWrapping="Wrap" LineHeight="22" TextAlignment="Center"/>
                            </ScrollViewer>

                            <Grid x:Name="GridDialogButtons">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnDialogCancel" Grid.Column="0" Content="İptal" Style="{StaticResource MaterialDesignFlatButton}" 
                                        Foreground="#7E84A3" Height="48" Margin="0,0,5,0" Click="BtnDialogResult_Click" Tag="False"/>

                                <Button x:Name="BtnDialogConfirm" Grid.Column="1" Content="Tamam" Foreground="White" Background="#1A1A24" BorderBrush="#1A1A24" 
                                        materialDesign:ButtonAssist.CornerRadius="14" Height="48" FontWeight="SemiBold"
                                        Click="BtnDialogResult_Click" Tag="True"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</Window>