<UserControl x:Class="Synctool.Views.ManualCampaignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="16" Padding="24" Margin="0,0,0,24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="56" Height="56" Background="#FFF1F2" CornerRadius="12">
                    <materialDesign:PackIcon Kind="TagPlus" Width="32" Height="32" Foreground="#E11D48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Kampanya Yönetim Merkezi" FontSize="26" FontWeight="ExtraBold" Foreground="#1E293B"/>
                    <TextBlock Text="Ürün bazlı özel kampanya ve duyuruları buradan yönetebilirsiniz." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol Panel -->
            <materialDesign:Card Grid.Column="0" UniformCornerRadius="16" Background="White" Margin="0,0,12,0" Padding="24">
                <StackPanel>
                    <TextBlock Text="1. ÜRÜN SEÇİMİ" FontSize="12" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,16"/>
                    
                    <ComboBox x:Name="CmbCategory" 
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Kategori Seçin"
                              Margin="0,0,0,24" Height="50">
                        <ComboBoxItem Content="Beyaz Eşya" Tag="WhiteGoods"/>
                        <ComboBoxItem Content="Kea" Tag="Kea"/>
                    </ComboBox>

                    <TextBlock Text="2. ÜRÜN KODLARI" FontSize="12" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtProductCodes" 
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             AcceptsReturn="True" 
                             Height="400"
                             VerticalScrollBarVisibility="Auto"
                             materialDesign:HintAssist.Hint="Kodları alt alta yapıştırın..."
                             TextWrapping="Wrap"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Sağ Panel -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Row="0" UniformCornerRadius="16" Background="White" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="3. KAMPANYA İÇERİĞİ" FontSize="12" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,16"/>
                        <TextBox x:Name="TxtDescription" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Kampanya detaylarını buraya yazın..."
                                 AcceptsReturn="True"
                                 Height="140"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Önizleme -->
                <materialDesign:Card Grid.Row="1" UniformCornerRadius="16" Background="White" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="EŞLEŞME ÖNİZLEMESİ" FontSize="12" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,16"/>
                        
                        <ScrollViewer Grid.Row="1">
                            <ListBox x:Name="LstPreview" BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Margin="0,4,0,12" Padding="16,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon Kind="{Binding Icon}" Foreground="{Binding Color}" Width="24" Height="24" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Code}" Margin="36,0,15,0" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Foreground="#1E293B"/>
                                                
                                                <Border Grid.Column="2" Background="{Binding Color}" CornerRadius="8" Padding="10,4" Opacity="0.9">
                                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>

                <Button Grid.Row="2" x:Name="BtnSave" 
                        Content="KAMPANYAYI KAYDET VE YAYINLA" 
                        Height="56" 
                        FontSize="12" FontWeight="ExtraBold"
                        materialDesign:ButtonAssist.CornerRadius="16"
                        Click="BtnSave_Click"
                        Background="#1E293B" BorderBrush="#1E293B"
                        Foreground="White"
                        Margin="0,16,0,0">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="4" Color="Black"/>
                    </Button.Effect>
                </Button>
            </Grid>
        </Grid>

        <materialDesign:Snackbar x:Name="MainSnackbar" Grid.RowSpan="2" MessageQueue="{materialDesign:MessageQueue}"/>
    </Grid>
</UserControl>
