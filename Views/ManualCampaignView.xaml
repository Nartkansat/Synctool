<UserControl x:Class="Synctool.Views.ManualCampaignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F8FAFC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             HEADER / BAŞLIK BÖLÜMÜ
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,20" Padding="24,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFF1F2" Offset="0"/>
                    <GradientStop Color="#FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.04" ShadowDepth="2" Color="#1E293B"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="52" Height="52" Background="#FFE4E6" CornerRadius="14">
                    <materialDesign:PackIcon Kind="TagPlus" Width="26" Height="26" Foreground="#E11D48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Kampanya Yönetim Merkezi" FontSize="22" FontWeight="Black" Foreground="#1E293B"/>
                    <TextBlock Text="Ürün bazlı özel kampanyaları, indirim koşullarını ve duyuruları tek bir panelden yönetin." FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             İÇERİK BÖLÜMÜ (SOL / SAĞ SÜTUNLAR)
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SOL PANEL: GİRDİLER (KATEGORİ & KODLAR) -->
            <materialDesign:Card Grid.Column="0" UniformCornerRadius="16" Background="White" Margin="0,0,10,0" Padding="20">
                <materialDesign:Card.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.03" ShadowDepth="3" Color="#1E293B"/>
                </materialDesign:Card.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <!-- ADIM 1 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="24" Height="24" Background="#EFF6FF" CornerRadius="12" VerticalAlignment="Center">
                                <TextBlock Text="1" Foreground="#2563EB" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="KATEGORİ SEÇİMİ" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <ComboBox x:Name="CmbCategory" 
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Kampanyanın Uygulanacağı Kategori"
                                  materialDesign:TextFieldAssist.UnderlineBrush="#E11D48"
                                  Margin="0,0,0,20" Height="48">
                            <ComboBoxItem Content="Beyaz Eşya" Tag="WhiteGoods"/>
                            <ComboBoxItem Content="Küçük Ev Aletleri (Kea)" Tag="Kea"/>
                        </ComboBox>

                        <!-- ADIM 2 -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                            <Border Width="24" Height="24" Background="#EFF6FF" CornerRadius="12" VerticalAlignment="Center">
                                <TextBlock Text="2" Foreground="#2563EB" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="ÜRÜN KODLARI" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Her satıra bir ürün kodu gelecek şekilde yazın veya yapıştırın." FontSize="11" Foreground="#94A3B8" Margin="34,0,0,8"/>
                    </StackPanel>

                    <TextBox x:Name="TxtProductCodes" Grid.Row="1"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             AcceptsReturn="True" 
                             VerticalScrollBarVisibility="Auto"
                             materialDesign:HintAssist.Hint="Ürün kodları..."
                             materialDesign:TextFieldAssist.UnderlineBrush="#E11D48"
                             TextWrapping="Wrap"
                             Margin="0,4,0,0"
                             Padding="16"
                             FontSize="13"
                             FontFamily="Consolas"/>
                </Grid>
            </materialDesign:Card>

            <!-- SAĞ PANEL: DETAYLAR, ÖNİZLEME VE KAYDET -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ADIM 3: AÇIKLAMA -->
                <materialDesign:Card Grid.Row="0" UniformCornerRadius="16" Background="White" Padding="20" Margin="0,0,0,16">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.03" ShadowDepth="3" Color="#1E293B"/>
                    </materialDesign:Card.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="24" Height="24" Background="#EFF6FF" CornerRadius="12" VerticalAlignment="Center">
                                <TextBlock Text="3" Foreground="#2563EB" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="KAMPANYA KOŞULLARI VE İÇERİĞİ" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBox x:Name="TxtDescription" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Kampanya detaylarını, indirim yüzdelerini ve geçerlilik koşullarını buraya girin..."
                                 materialDesign:TextFieldAssist.UnderlineBrush="#E11D48"
                                 AcceptsReturn="True"
                                 Height="110"
                                 TextWrapping="Wrap"
                                 FontSize="13"
                                 Padding="16"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ÖNİZLEME BÖLÜMÜ -->
                <materialDesign:Card Grid.Row="1" UniformCornerRadius="16" Background="White" Padding="20">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.03" ShadowDepth="3" Color="#1E293B"/>
                    </materialDesign:Card.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                            <Border Width="24" Height="24" Background="#ECFDF5" CornerRadius="12" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Eye" Width="14" Height="14" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="KOD EŞLEŞME ÖNİZLEMESİ" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="(İlk 100 Ürün Gösterilir)" FontSize="11" Foreground="#94A3B8" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ListBox x:Name="LstPreview" BorderThickness="0" Background="Transparent" Padding="0" HorizontalContentAlignment="Stretch">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Eşleşme durumuna göre dinamik renklendirilen yumuşak modern border -->
                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="14,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- İkon ve Kod -->
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="{Binding Icon}" Foreground="{Binding Color}" Width="20" Height="20" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Code}" Margin="12,0,0,0" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Foreground="#1E293B" FontFamily="Consolas"/>
                                                </StackPanel>
                                                
                                                <!-- Durum Badge -->
                                                <Border Grid.Column="2" CornerRadius="6" Padding="8,3" BorderBrush="{Binding Color}" BorderThickness="1" Background="White">
                                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{Binding Color}" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>

                <!-- KAYDET BUTONU -->
                <Button Grid.Row="2" x:Name="BtnSave" 
                        Height="50" 
                        FontSize="13" FontWeight="Bold"
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Click="BtnSave_Click"
                        BorderBrush="Transparent"
                        Foreground="White"
                        Margin="0,16,0,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E02020" Offset="0"/>
                            <GradientStop Color="#B91C1C" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.15" ShadowDepth="4" Color="#E02020"/>
                    </Button.Effect>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="SendCheck" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="KAMPANYAYI KAYDET VE HEMEN YAYINLA" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <materialDesign:Snackbar x:Name="MainSnackbar" Grid.RowSpan="2" MessageQueue="{materialDesign:MessageQueue}"/>
    </Grid>
</UserControl>
