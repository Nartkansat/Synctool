<Window x:Class="ArcelikExcelApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Synctool Giriş" Height="750" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Icon="/Assets/synctoolAppIcon.png">

    <Border CornerRadius="20" Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#888888" BlurRadius="25" Opacity="0.3" Direction="270" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="200"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo Area -->
            <Border Grid.Row="0" Background="#E02020" CornerRadius="20,20,0,0">
                <StackPanel VerticalAlignment="Center">
                    <Viewbox Width="230" Height="Auto" Margin="10" HorizontalAlignment="Center">
                        <Image Source="/Assets/synctool.png" RenderOptions.BitmapScalingMode="HighQuality" />
                    </Viewbox>
                </StackPanel>
            </Border>

            <!-- Close Button -->
            <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                    Background="Transparent" BorderBrush="Transparent" 
                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Margin="10" Click="BtnClose_Click">
                <materialDesign:PackIcon Kind="Close" Foreground="White" Width="20" Height="20"/>
            </Button>

            <!-- Form Area -->
            <Grid Grid.Row="1">
                <!-- LOGIN VIEW -->
                <ScrollViewer x:Name="ViewLogin" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                    <StackPanel Margin="40,60,40,10">
                        <TextBlock Text="Giriş Yap" FontSize="24" FontWeight="Bold" Foreground="#1A1A24" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        
                        <TextBox x:Name="TxtUsername" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Kullanıcı Adı"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 Margin="0,0,0,15" Height="50" VerticalContentAlignment="Center"/>

                        <Grid Margin="0,0,0,15" Height="50">
                            <PasswordBox x:Name="TxtPassword" 
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Şifre"
                                         Padding="16,0,45,0" VerticalContentAlignment="Center" Height="50"/>
                            <TextBox x:Name="TxtPasswordVisible" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Şifre"
                                     Visibility="Collapsed" Padding="16,0,45,0" VerticalContentAlignment="Center" Height="50"/>
                            <Button x:Name="BtnShowPassword"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Width="30" Height="30" Click="BtnShowPassword_Click">
                                <materialDesign:PackIcon x:Name="IconShowPassword" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                            </Button>
                        </Grid>

                        <TextBox x:Name="TxtLicenseKey" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Lisans Anahtarı"
                                 Visibility="Collapsed" Margin="0,0,0,10" Height="50" VerticalContentAlignment="Center"/>

                        <CheckBox x:Name="ChkRememberMe" Content="Beni Hatırla (30 Gün)" 
                                  Foreground="#666A7D" Margin="0,0,0,15"/>

                        <Button x:Name="BtnLogin" Content="Giriş Yap" Foreground="White" Height="45" IsDefault="True"
                                materialDesign:ButtonAssist.CornerRadius="10" Background="#E02020" BorderBrush="#E02020"
                                FontSize="16" FontWeight="Bold" Click="BtnLogin_Click"/>

                        <TextBlock HorizontalAlignment="Center" Margin="0,15,0,0">
                            <Hyperlink Click="LnkForgotPassword_Click" Foreground="#666A7D" TextDecorations="{x:Null}">Şifremi Unuttum</Hyperlink>
                        </TextBlock>

                        <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Run Text="Hesabınız yok mu?" Foreground="#666A7D"/>
                            <Hyperlink Click="BtnSwitchToRegister_Click" Foreground="#E02020" FontWeight="Bold" TextDecorations="{x:Null}"> Kayıt Ol</Hyperlink>
                        </TextBlock>

                        <TextBlock x:Name="TxtError" Foreground="#D32F2F" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" 
                                   Margin="0,15,0,0" Visibility="Collapsed" LineHeight="18"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- REGISTER VIEW -->
                <ScrollViewer x:Name="ViewRegister" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Margin="40,20,40,10">
                        <TextBlock Text="Kayıt Ol" FontSize="24" FontWeight="Bold" Foreground="#1A1A24" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <TextBox x:Name="TxtRegUsername" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Kullanıcı Adı"
                                 Margin="0,0,0,15" Height="50" VerticalContentAlignment="Center"/>

                        <TextBox x:Name="TxtRegDealerName" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Bayi Adı"
                                 Margin="0,0,0,15" Height="50" VerticalContentAlignment="Center"/>

                        <Grid Margin="0,0,0,15" Height="50">
                            <PasswordBox x:Name="TxtRegPassword" 
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Şifre"
                                         Padding="16,0,45,0" VerticalContentAlignment="Center" Height="50"/>
                            <TextBox x:Name="TxtRegPasswordVisible" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Şifre"
                                     Visibility="Collapsed" Padding="16,0,45,0" VerticalContentAlignment="Center" Height="50"/>
                            <Button x:Name="BtnRegShowPassword"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Width="30" Height="30" Click="BtnRegShowPassword_Click">
                                <materialDesign:PackIcon x:Name="IconRegShowPassword" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                            </Button>
                        </Grid>

                        <Grid Margin="0,0,0,15" Height="50">
                            <PasswordBox x:Name="TxtRegPasswordConfirm" 
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Şifre (Tekrar)"
                                         Padding="16,0,45,0" VerticalContentAlignment="Center" Height="50"/>
                            <TextBox x:Name="TxtRegPasswordConfirmVisible" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Şifre (Tekrar)"
                                     Visibility="Collapsed" Padding="16,0,45,0" VerticalContentAlignment="Center" Height="50"/>
                            <Button x:Name="BtnRegShowPasswordConfirm"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                    Width="30" Height="30" Click="BtnRegShowPasswordConfirm_Click">
                                <materialDesign:PackIcon x:Name="IconRegShowPasswordConfirm" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                            </Button>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <CheckBox x:Name="ChkAgreement" Foreground="#666A7D" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Margin="5,0,0,0">
                                <Hyperlink Click="LnkAgreement_Click" Foreground="#E02020" TextDecorations="{x:Null}">Kullanıcı Sözleşmesini</Hyperlink>
                                <Run Text=" okudum."/>
                            </TextBlock>
                        </StackPanel>

                        <Button x:Name="BtnRegister" Content="Kayıt Ol" Foreground="White" Height="45"
                                materialDesign:ButtonAssist.CornerRadius="10" Background="#1A1A24" BorderBrush="#1A1A24"
                                FontSize="16" FontWeight="Bold" Click="BtnRegister_Click"/>

                        <TextBlock HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Run Text="Zaten hesabınız var mı?" Foreground="#666A7D"/>
                            <Hyperlink Click="BtnSwitchToLogin_Click" Foreground="#E02020" FontWeight="Bold" TextDecorations="{x:Null}"> Giriş Yap</Hyperlink>
                        </TextBlock>

                        <TextBlock x:Name="TxtRegError" Foreground="#D32F2F" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" 
                                   Margin="0,15,0,0" Visibility="Collapsed" LineHeight="18"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <TextBlock Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                       Margin="0,10,0,15" Text="© 2026 Synctool Maliyet Yönetim Sistemi" Foreground="#BDBDBD" FontSize="10"/>

            <Grid x:Name="ResetOverlay" Grid.RowSpan="2" Background="#CCF3F5F9" Visibility="Collapsed">
                <materialDesign:Card Width="360" VerticalAlignment="Center" HorizontalAlignment="Center" UniformCornerRadius="20" Padding="0">
                    <Grid>
                        <Border Padding="30">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="LockReset" Width="40" Height="40" Foreground="#E02020" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                <TextBlock Text="Şifre Sıfırlama" FontSize="22" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center" Foreground="#1A1A24"/>
                                <TextBlock Text="Hesabınızı kurtarmak için gerekli bilgileri girin." FontSize="13" Foreground="#666A7D" TextWrapping="Wrap" Margin="0,0,0,25" TextAlignment="Center"/>
                                
                                <TextBox x:Name="TxtResetUsername" materialDesign:HintAssist.Hint="Kullanıcı Adı" Margin="0,0,0,15" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="60" VerticalContentAlignment="Center" Padding="16,0,16,0"/>
                                <TextBox x:Name="TxtResetLicense" materialDesign:HintAssist.Hint="Lisans Anahtarı" Margin="0,0,0,15" Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="60" VerticalContentAlignment="Center" Padding="16,0,16,0"/>
                                <Grid Margin="0,0,0,10" Height="60">
                                    <PasswordBox x:Name="TxtResetNewPassword" 
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                 materialDesign:HintAssist.Hint="Yeni Şifre"
                                                 Padding="16,0,45,0"
                                                 VerticalContentAlignment="Center"
                                                 Height="60"/>
                                    <TextBox x:Name="TxtResetNewPasswordVisible" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Yeni Şifre"
                                             Visibility="Collapsed"
                                             Padding="16,0,45,0"
                                             VerticalContentAlignment="Center"
                                             Height="60"/>
                                    <Button x:Name="BtnShowResetPassword"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                            Width="30" Height="30" Click="BtnShowResetPassword_Click">
                                        <materialDesign:PackIcon x:Name="IconShowResetPassword" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                                    </Button>
                                </Grid>

                                <Grid Margin="0,0,0,10" Height="60">
                                    <PasswordBox x:Name="TxtResetNewPasswordConfirm" 
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                 materialDesign:HintAssist.Hint="Yeni Şifre (Tekrar)"
                                                 Padding="16,0,45,0"
                                                 VerticalContentAlignment="Center"
                                                 Height="60"/>
                                    <TextBox x:Name="TxtResetNewPasswordConfirmVisible" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Yeni Şifre (Tekrar)"
                                             Visibility="Collapsed"
                                             Padding="16,0,45,0"
                                             VerticalContentAlignment="Center"
                                             Height="60"/>
                                    <Button x:Name="BtnShowResetPasswordConfirm"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                            Width="30" Height="30" Click="BtnShowResetPasswordConfirm_Click">
                                        <materialDesign:PackIcon x:Name="IconShowResetPasswordConfirm" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                                    </Button>
                                </Grid>
                                
                                <TextBlock x:Name="TxtResetError" Foreground="#D32F2F" FontSize="12" Margin="0,5,0,15" HorizontalAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center"/>

                                <Button x:Name="BtnConfirmReset" Content="Şifreyi Sıfırla" Foreground="White" Background="#E02020" BorderBrush="#E02020" Height="50" materialDesign:ButtonAssist.CornerRadius="12" FontWeight="Bold" Click="BtnConfirmReset_Click"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Close Button for Modal -->
                        <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                                Width="30" Height="30" Background="Transparent" BorderBrush="Transparent"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Click="BtnCancelReset_Click">
                            <materialDesign:PackIcon Kind="Close" Foreground="#666A7D" Width="18" Height="18"/>
                        </Button>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- Custom Premium Toast Notification -->
            <materialDesign:Card x:Name="ToastCard" Visibility="Collapsed" Opacity="0"
                                VerticalAlignment="Top" HorizontalAlignment="Right" 
                                Margin="0,30,30,0" UniformCornerRadius="12" 
                                Background="White" Width="320"
                                materialDesign:ElevationAssist.Elevation="Dp6">
                <materialDesign:Card.RenderTransform>
                    <TranslateTransform X="50"/>
                </materialDesign:Card.RenderTransform>
                <Border BorderBrush="#4CAF50" BorderThickness="4,0,0,0" Padding="20,15">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50" Width="24" Height="24" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtToastMessage" Text="İşlem Başarılı" 
                                   Foreground="#1A1A24" FontWeight="SemiBold" FontSize="14" 
                                   Margin="15,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </materialDesign:Card>
            <!-- Modern Dialog Overlay -->
            <Grid x:Name="ModernDialogOverlay" Grid.RowSpan="2" Visibility="Collapsed">
                <Border Background="#111A1A24">
                    <Border.Effect>
                        <BlurEffect Radius="15"/>
                    </Border.Effect>
                </Border>
                <Grid Background="#22FFFFFF">
                    <materialDesign:Card Width="350" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                        UniformCornerRadius="25" Background="White">
                        <materialDesign:Card.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.2" Direction="270" ShadowDepth="10"/>
                        </materialDesign:Card.Effect>
                        <Border Padding="30">
                            <StackPanel>
                                <Border x:Name="BorderDialogIcon" Width="50" Height="50" Background="#E3F2FD" CornerRadius="25" Margin="0,0,0,15">
                                    <materialDesign:PackIcon x:Name="IconDialog" Kind="Information" Width="26" Height="26" Foreground="#2196F3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <TextBlock x:Name="TxtDialogTitle" Text="Başlık" FontSize="20" FontWeight="Bold" 
                                           Foreground="#1A1A24" Margin="0,0,0,8" HorizontalAlignment="Center" TextAlignment="Center"/>
                                
                                <TextBlock x:Name="TxtDialogMessage" Text="Mesaj içeriği..." FontSize="14" 
                                           Foreground="#666A7D" TextWrapping="Wrap" LineHeight="20" TextAlignment="Center" Margin="0,0,0,25"/>
                                
                                <Button x:Name="BtnDialogConfirm" Content="Tamam" Foreground="White" Background="#1A1A24" BorderBrush="#1A1A24" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="45" FontWeight="SemiBold"
                                        Click="BtnDialogResult_Click"/>
                            </StackPanel>
                        </Border>
                    </materialDesign:Card>
                </Grid>
            </Grid>

            <!-- Agreement Overlay -->
            <Grid x:Name="AgreementOverlay" Grid.RowSpan="3" Background="#CCF3F5F9" Visibility="Collapsed">
                <materialDesign:Card Width="400" Height="500" VerticalAlignment="Center" HorizontalAlignment="Center" UniformCornerRadius="20" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#1A1A24" Padding="20">
                            <TextBlock x:Name="TxtAgreementVersion" Text="Kullanıcı Sözleşmesi" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" Margin="20">
                            <TextBlock x:Name="TxtAgreementContent" TextWrapping="Wrap" Foreground="#333" FontSize="14" LineHeight="22"/>
                        </ScrollViewer>
                        <Border Grid.Row="2" Background="#F1F5F9" Padding="20">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Kapat" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,10,0" Click="BtnCloseAgreement_Click"/>
                                <Button x:Name="BtnAcceptAgreement" Content="Kabul Et" Background="#10B981" BorderBrush="#10B981" Foreground="White" Click="BtnAcceptAgreement_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Border>
</Window>
