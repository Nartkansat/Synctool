<Window x:Class="Synctool.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Synctool Giriş" Width="920" Height="560"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Icon="/Assets/synctoolAppIcon.png">

    <Border CornerRadius="20" Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#888888" BlurRadius="25" Opacity="0.3" Direction="270" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <!-- 2 Columns: Left Banner & Right Forms -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Banner (Red background with logo) -->
            <Border Grid.Column="0" Background="#E02020" CornerRadius="20,0,0,20">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                        <Viewbox Width="190" Height="Auto" Margin="0,0,0,20">
                            <Image Source="/Assets/synctool.png" RenderOptions.BitmapScalingMode="HighQuality" />
                        </Viewbox>
                        <TextBlock Text="Maliyet Hesaplama Aracı" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Synctool ile maliyetlerinizi anlık hesaplayın ve yönetin." FontSize="13" Foreground="#FFCDCD" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                    
                    <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                               Margin="0,0,0,25" Text="© 2026 Synctool Maliyet Yönetim Sistemi" Foreground="#FFCDCD" FontSize="10"/>
                </Grid>
            </Border>

            <!-- Right Panel (Forms) -->
            <Grid Grid.Column="1" Margin="40,30,40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Close Button inside Right Panel -->
                <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}" 
                        Background="Transparent" BorderBrush="Transparent" 
                        HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Margin="0,-15,-20,0" Click="BtnClose_Click">
                    <materialDesign:PackIcon Kind="Close" Foreground="#64748B" Width="22" Height="22"/>
                </Button>

                <!-- Forms Container -->
                <Grid Grid.Row="0" VerticalAlignment="Center">
                    
                    <!-- LOGIN VIEW -->
                    <ScrollViewer x:Name="ViewLogin" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                        <StackPanel MaxWidth="380" HorizontalAlignment="Stretch" Margin="0,10">
                            <TextBlock Text="Giriş Yap" FontSize="26" FontWeight="Bold" Foreground="#1A1A24" HorizontalAlignment="Left" Margin="0,0,0,24"/>
                            
                            <!-- Kullanıcı Adı -->
                            <Grid Margin="0,0,0,16">
                                <TextBox x:Name="TxtUsername" 
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Kullanıcı Adı"
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Height="46" Padding="40,0,30,0" VerticalContentAlignment="Center"/>
                                <materialDesign:PackIcon Kind="AccountOutline" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Şifre -->
                            <Grid Margin="0,0,0,16" Height="46">
                                <PasswordBox x:Name="TxtPassword" 
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             materialDesign:HintAssist.Hint="Şifre"
                                             Padding="40,0,45,0" VerticalContentAlignment="Center" Height="46"/>
                                <TextBox x:Name="TxtPasswordVisible" 
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Şifre"
                                         Visibility="Collapsed" Padding="40,0,45,0" VerticalContentAlignment="Center" Height="46"/>
                                <materialDesign:PackIcon Kind="LockOutline" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                                <Button x:Name="BtnShowPassword"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                        Width="30" Height="30" Click="BtnShowPassword_Click">
                                    <materialDesign:PackIcon x:Name="IconShowPassword" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                                </Button>
                            </Grid>

                            <!-- Lisans Anahtarı -->
                            <Grid Margin="0,0,0,16" Visibility="{Binding ElementName=TxtLicenseKey, Path=Visibility}">
                                <TextBox x:Name="TxtLicenseKey" 
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Lisans Anahtarı"
                                         Height="46" Padding="40,0,30,0" VerticalContentAlignment="Center"
                                         Visibility="Collapsed"/>
                                <materialDesign:PackIcon Kind="KeyOutline" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Beni Hatırla & Şifremi Unuttum -->
                            <Grid Margin="0,0,0,20">
                                <CheckBox x:Name="ChkRememberMe" Content="Beni Hatırla (30 Gün)" 
                                          Foreground="#666A7D" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Hyperlink Click="LnkForgotPassword_Click" Foreground="#E02020" FontWeight="SemiBold" TextDecorations="{x:Null}">Şifremi Unuttum</Hyperlink>
                                </TextBlock>
                            </Grid>

                            <!-- Giriş Yap Button -->
                            <Button x:Name="BtnLogin" Content="Giriş Yap" Foreground="White" Height="46" IsDefault="True"
                                    materialDesign:ButtonAssist.CornerRadius="12" Background="#E02020" BorderBrush="#E02020"
                                    FontSize="16" FontWeight="Bold" Click="BtnLogin_Click" Margin="0,0,0,16"/>

                            <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Run Text="Hesabınız yok mu?" Foreground="#666A7D"/>
                                <Hyperlink Click="BtnSwitchToRegister_Click" Foreground="#E02020" FontWeight="Bold" TextDecorations="{x:Null}"> Kayıt Ol</Hyperlink>
                            </TextBlock>

                            <!-- ── Hata Mesajı ── -->
                            <Border x:Name="LoginErrorBorder" Visibility="Collapsed"
                                    Background="#FFF5F5" CornerRadius="10"
                                    BorderBrush="#FCA5A5" BorderThickness="1"
                                    Padding="14,10" Margin="0,15,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon x:Name="BorderErrorIcon" Kind="AlertCircleOutline"
                                             Foreground="#EF4444" Width="18" Height="18"
                                             VerticalAlignment="Top" Margin="0,1,0,0"/>
                                    <TextBlock x:Name="TxtError" Foreground="#B91C1C"
                                               FontSize="13" TextWrapping="Wrap"
                                               Margin="10,0,0,0" LineHeight="18"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- PASSWORD RESET VIEW -->
                    <ScrollViewer x:Name="ViewReset" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel MaxWidth="380" HorizontalAlignment="Stretch" Margin="0,10">
                            <TextBlock Text="Şifre Sıfırlama" FontSize="26" FontWeight="Bold" Foreground="#1A1A24" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                            <TextBlock Text="Hesabınızı kurtarmak için gerekli bilgileri girin." FontSize="13" Foreground="#666A7D" Margin="0,0,0,20"/>
                            
                            <!-- Kullanıcı Adı -->
                            <Grid Margin="0,0,0,12">
                                <TextBox x:Name="TxtResetUsername" 
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Kullanıcı Adı"
                                         Height="46" Padding="40,0,30,0" VerticalContentAlignment="Center"/>
                                <materialDesign:PackIcon Kind="AccountOutline" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                                     
                            <!-- Lisans Anahtarı -->
                            <Grid Margin="0,0,0,16">
                                <TextBox x:Name="TxtResetLicense" 
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Lisans Anahtarı"
                                         Height="46" Padding="40,0,30,0" VerticalContentAlignment="Center"/>
                                <materialDesign:PackIcon Kind="KeyOutline" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                            </Grid>

                            <StackPanel x:Name="PanelResetPasswords" Visibility="Collapsed" Margin="0,0,0,12">
                                <!-- Doğrulama Kodu -->
                                <Grid Margin="0,0,0,12">
                                    <TextBox x:Name="TxtResetCode" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="6 Haneli Doğrulama Kodu"
                                             Height="46" Padding="40,0,30,0" VerticalContentAlignment="Center" MaxLength="6"/>
                                    <materialDesign:PackIcon Kind="Numeric" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                                </Grid>
                                         
                                <!-- Yeni Şifre -->
                                <Grid Margin="0,0,0,12" Height="46">
                                    <PasswordBox x:Name="TxtResetNewPassword" 
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                 materialDesign:HintAssist.Hint="Yeni Şifre"
                                                 Padding="40,0,45,0" VerticalContentAlignment="Center" Height="46"/>
                                    <TextBox x:Name="TxtResetNewPasswordVisible" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Yeni Şifre"
                                             Visibility="Collapsed" Padding="40,0,45,0" VerticalContentAlignment="Center" Height="46"/>
                                    <materialDesign:PackIcon Kind="LockOutline" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                                    <Button x:Name="BtnShowResetPassword"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                            Width="30" Height="30" Click="BtnShowResetPassword_Click">
                                        <materialDesign:PackIcon x:Name="IconShowResetPassword" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                                    </Button>
                                </Grid>

                                <!-- Yeni Şifre Tekrar -->
                                <Grid Height="46">
                                    <PasswordBox x:Name="TxtResetNewPasswordConfirm" 
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                 materialDesign:HintAssist.Hint="Yeni Şifre (Tekrar)"
                                                 Padding="40,0,45,0" VerticalContentAlignment="Center" Height="46"/>
                                    <TextBox x:Name="TxtResetNewPasswordConfirmVisible" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Yeni Şifre (Tekrar)"
                                             Visibility="Collapsed" Padding="40,0,45,0" VerticalContentAlignment="Center" Height="46"/>
                                    <materialDesign:PackIcon Kind="LockCheckOutline" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                                    <Button x:Name="BtnShowResetPasswordConfirm"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                            Width="30" Height="30" Click="BtnShowResetPasswordConfirm_Click">
                                        <materialDesign:PackIcon x:Name="IconShowResetPasswordConfirm" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                            
                            <!-- ── Sıfırlama Hata Mesajı ── -->
                            <Border x:Name="ResetErrorBorder" Visibility="Collapsed"
                                    Background="#FFF5F5" CornerRadius="10"
                                    BorderBrush="#FCA5A5" BorderThickness="1"
                                    Padding="14,10" Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon x:Name="BorderResetErrorIcon" Kind="AlertCircleOutline"
                                             Foreground="#EF4444" Width="18" Height="18"
                                             VerticalAlignment="Top" Margin="0,1,0,0"/>
                                    <TextBlock x:Name="TxtResetError" Foreground="#B91C1C"
                                               FontSize="13" TextWrapping="Wrap"
                                               Margin="10,0,0,0" LineHeight="18"/>
                                </StackPanel>
                            </Border>

                            <!-- Buttons -->
                            <StackPanel Margin="0,0,0,10">
                                <Button x:Name="BtnSendResetCode" Content="Kod Gönder" Foreground="White" Background="#1A1A24" BorderBrush="#1A1A24" Height="46" materialDesign:ButtonAssist.CornerRadius="12" FontWeight="Bold" Click="BtnSendResetCode_Click" Margin="0,0,0,10"/>
                                <Button x:Name="BtnConfirmReset" Content="Şifreyi Sıfırla" Foreground="White" Background="#E02020" BorderBrush="#E02020" Height="46" materialDesign:ButtonAssist.CornerRadius="12" FontWeight="Bold" Click="BtnConfirmReset_Click" Visibility="Collapsed" Margin="0,0,0,10"/>
                                <Button x:Name="BtnResendResetCode" Content="Kodu Tekrar Gönder" Style="{StaticResource MaterialDesignOutlinedButton}" Height="38" materialDesign:ButtonAssist.CornerRadius="10" FontWeight="SemiBold" Click="BtnSendResetCode_Click" Visibility="Collapsed"/>
                            </StackPanel>
                            
                            <TextBlock HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="13">
                                <Hyperlink Click="BtnCancelReset_Click" Foreground="#E02020" FontWeight="Bold" TextDecorations="{x:Null}">Giriş Yap'a Dön</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Custom Toast Notification Overlay -->
            <materialDesign:Card x:Name="ToastCard" Grid.ColumnSpan="2" Visibility="Collapsed" Opacity="0"
                                VerticalAlignment="Top" HorizontalAlignment="Right" 
                                Margin="0,30,30,0" UniformCornerRadius="12" 
                                Background="White" Width="320"
                                materialDesign:ElevationAssist.Elevation="Dp6">
                <materialDesign:Card.RenderTransform>
                    <TranslateTransform X="50"/>
                </materialDesign:Card.RenderTransform>
                <Border BorderBrush="#4CAF50" BorderThickness="4,0,0,0" Padding="20,15">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50" Width="24" Height="24" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtToastMessage" Text="İşlem Başarılı" 
                                   Foreground="#1A1A24" FontWeight="SemiBold" FontSize="14" 
                                   Margin="15,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </materialDesign:Card>

            <!-- Modern Dialog Overlay -->
            <Grid x:Name="ModernDialogOverlay" Grid.ColumnSpan="2" Visibility="Collapsed">
                <Border Background="#111A1A24">
                    <Border.Effect>
                        <BlurEffect Radius="15"/>
                    </Border.Effect>
                </Border>
                <Grid Background="#22FFFFFF">
                    <materialDesign:Card Width="350" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                        UniformCornerRadius="25" Background="White">
                        <materialDesign:Card.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.2" Direction="270" ShadowDepth="10"/>
                        </materialDesign:Card.Effect>
                        <Border Padding="30">
                            <StackPanel>
                                <Border x:Name="BorderDialogIcon" Width="50" Height="50" Background="#E3F2FD" CornerRadius="25" Margin="0,0,0,15">
                                    <materialDesign:PackIcon x:Name="IconDialog" Kind="Information" Width="26" Height="26" Foreground="#2196F3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <TextBlock x:Name="TxtDialogTitle" Text="Başlık" FontSize="20" FontWeight="Bold" 
                                           Foreground="#1A1A24" Margin="0,0,0,8" HorizontalAlignment="Center" TextAlignment="Center"/>
                                
                                <TextBlock x:Name="TxtDialogMessage" Text="Mesaj içeriği..." FontSize="14" 
                                           Foreground="#666A7D" TextWrapping="Wrap" LineHeight="20" TextAlignment="Center" Margin="0,0,0,25"/>
                                
                                <Button x:Name="BtnDialogConfirm" Content="Tamam" Foreground="White" Background="#1A1A24" BorderBrush="#1A1A24" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="45" FontWeight="SemiBold"
                                        Click="BtnDialogResult_Click"/>
                            </StackPanel>
                        </Border>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>