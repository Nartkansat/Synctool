<UserControl x:Class="Synctool.Views.KeaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F4F6F8"
             Loaded="UserControl_Loaded"
             Focusable="True"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- Arama Çubuğu -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <TextBox x:Name="TxtSearch" Grid.Column="0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Ürün Kodu veya Adı Ara (Ctrl+F)"
                         materialDesign:TextFieldAssist.UnderlineBrush="#E02020"
                         CaretBrush="#E02020"
                         TextChanged="TxtSearch_TextChanged">
                </TextBox>
                <materialDesign:PackIcon Kind="Magnify" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#94A3B8"/>
                
                <!-- Valor Filter -->
                <ComboBox x:Name="CboValorFilter" Grid.Column="1" Margin="16,0,0,0"
                           Style="{StaticResource MaterialDesignOutlinedComboBox}"
                           materialDesign:TextFieldAssist.UnderlineBrush="#E02020"
                           materialDesign:HintAssist.Hint="Fiyat Tipi (Valör)"
                           Height="48"
                           VerticalContentAlignment="Center"
                           Padding="10,0"
                           SelectionChanged="CboValorFilter_SelectionChanged">
                    <ComboBoxItem Content="Ayarlanan Valörler" Tag="Personal" IsSelected="True"/>
                    <ComboBoxItem Content="60 Günlük (Varsayılan)" Tag="WholesalePrice60"/>
                    <ComboBoxItem Content="Peşin" Tag="CashPrice"/>
                    <ComboBoxItem Content="30 Günlük" Tag="WholesalePrice30"/>
                    <ComboBoxItem Content="90 Günlük" Tag="WholesalePrice90"/>
                    <ComboBoxItem Content="120 Günlük" Tag="WholesalePrice120"/>
                </ComboBox>

                <TextBlock Grid.Column="2" x:Name="TxtTotalCount" Text="Toplam: 0 Ürün" 
                           VerticalAlignment="Center" HorizontalAlignment="Left" Margin="16,0,0,0" Foreground="#64748B" FontWeight="SemiBold"/>

                <!-- Valör Ayarları Butonu -->
                <Button Grid.Column="3" x:Name="BtnOpenValorSettings"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#E02020" BorderBrush="#E02020"
                        Height="38" Padding="14,0"
                        Click="BtnOpenValorSettings_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CalendarClock" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Valör Ayarları" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <materialDesign:Card Grid.Row="1" Margin="16,16,16,8" UniformCornerRadius="10">
            <DataGrid x:Name="GridKea" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="White"
                      BorderThickness="0"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      materialDesign:DataGridAssist.CellPadding="14,8,8,8"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Excel'de Aç" Click="MenuItem_OpenExcel_Click">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="MicrosoftExcel" Foreground="#10B981"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Arçelik.com.tr'de Aç" Click="MenuItem_OpenInArcelik_Click">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="Web" Foreground="#E02020"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Eski Fiyatları Gör" Click="MenuItem_ViewHistory_Click">
                            <MenuItem.Icon>
                                <materialDesign:PackIcon Kind="History" Foreground="#F59E0B"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ürün Kodu" Binding="{Binding ProductCode}" Width="115"/>
                    <DataGridTextColumn Header="Ürün Adı" Binding="{Binding ProductName}" Width="*" MinWidth="150"/>
                    <DataGridTextColumn Header="Valör" Binding="{Binding ActiveValorText}" Width="95"/>
                    <DataGridTextColumn x:Name="ColBasePrice" Header="Baz Fiyat" Binding="{Binding PricePP, StringFormat={}{0:N2} ₺}" Width="110">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="İndirim" Binding="{Binding DiscountAmount, StringFormat={}{0:N2} ₺}" Width="90">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Net İndirim" Binding="{Binding PriceConversion, StringFormat={}{0:N2} ₺}" Width="110">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Net Maliyet" Binding="{Binding PurchasePrice, StringFormat={}{0:N2} ₺}" Width="115">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#16A34A"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn x:Name="ColCardPrice" Header="Kart Fiyatı" Binding="{Binding CardPurchasePrice, StringFormat={}{0:N2} ₺}" Width="135">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#DC2626"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <!--<DataGridTextColumn Header="Tarih" Binding="{Binding CreatedDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>-->

                    <!-- Manuel Kampanya Butonu -->
                    <DataGridTemplateColumn Header="Kampanya" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="BtnShowManualCampaign"
                                        Click="BtnShowManualCampaign_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Height="28" Padding="8,0" HorizontalAlignment="Left"
                                        Visibility="{Binding HasManualCampaign, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Tag" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Kampanya" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Aksiyonlar" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Sepete Ekle"
                                            Width="32" Height="32"
                                            Click="BtnAddToCart_Click">
                                        <materialDesign:PackIcon Kind="CartPlus" Foreground="#3949AB" Width="20" Height="20"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Excel'de Aç"
                                            Width="32" Height="32"
                                            Click="MenuItem_OpenExcel_Click">
                                        <materialDesign:PackIcon Kind="MicrosoftExcel" Foreground="#10B981" Width="20" Height="20"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Eski Fiyatları Gör"
                                            Width="32" Height="32"
                                            Click="MenuItem_ViewHistory_Click">
                                        <materialDesign:PackIcon Kind="History" Foreground="#F59E0B" Width="20" Height="20"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Arçelik.com.tr'de Aç"
                                            Width="32" Height="32"
                                            Click="MenuItem_OpenInArcelik_Click">
                                        <materialDesign:PackIcon Kind="Web" Foreground="#E02020" Width="20" Height="20"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- Sayfalama (Pagination) -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnPrev" Content="Önceki" Style="{StaticResource MaterialDesignOutlinedButton}" 
                        Foreground="#E02020" BorderBrush="#E02020"
                        Height="32" Padding="12,0" Margin="0,0,16,0" Click="BtnPrev_Click"/>
                
                <TextBlock x:Name="TxtPageInfo" Text="Sayfa 1 / 1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569"/>
                
                <Button x:Name="BtnNext" Content="Sonraki" Style="{StaticResource MaterialDesignOutlinedButton}" 
                        Foreground="#E02020" BorderBrush="#E02020"
                        Height="32" Padding="12,0" Margin="16,0,0,0" Click="BtnNext_Click"/>
            </StackPanel>
        </Border>
        
        <!-- Loading Overlay -->
        <Grid x:Name="OverlayLoading" Grid.RowSpan="3" Background="#AAFFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Width="40" Height="40" Foreground="#E02020" HorizontalAlignment="Center"/>
                <TextBlock Text="Veriler Yükleniyor..." Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#1C2B4A"/>
            </StackPanel>
        </Grid>

        <!-- Manuel Kampanya Detay Overlay -->
        <Grid x:Name="ManualCampaignOverlay" Grid.RowSpan="3" Visibility="Collapsed">
            <materialDesign:Card Width="600" MaxHeight="650" VerticalAlignment="Center" HorizontalAlignment="Center" UniformCornerRadius="12" Background="White">
                <materialDesign:Card.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.2" Direction="270" ShadowDepth="10"/>
                </materialDesign:Card.Effect>
                
                <Grid>
                    <!-- Sol Vurgu Çubuğu (Accent Bar) -->
                    <Border Width="6" Background="#E11D48" HorizontalAlignment="Left" CornerRadius="12,0,0,12"/>
                    
                    <Grid Margin="6,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header -->
                        <Border Grid.Row="0" Padding="32,24" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="48" Height="48" Background="#FFF1F2" CornerRadius="10">
                                        <materialDesign:PackIcon Kind="TagCheck" Width="24" Height="24" Foreground="#E11D48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="KAMPANYA DETAYI" FontSize="12" FontWeight="Black" Foreground="#E11D48" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="TxtManualCampaignProductName" Text="Ürün Bilgisi" FontSize="18" FontWeight="Bold" Foreground="#1E293B" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Style="{StaticResource MaterialDesignIconButton}" Width="40" Height="40"
                                        Click="BtnCloseManualCampaign_Click" Foreground="#94A3B8">
                                    <materialDesign:PackIcon Kind="Close" Width="22" Height="22"/>
                                </Button>
                            </Grid>
                        </Border>
                        
                        <!-- Content -->
                        <Grid Grid.Row="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                                <Border Padding="32,24">
                                    <StackPanel>
                                        <TextBlock Text="Aktif Koşullar" FontSize="13" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,16"/>
                                        
                                        <ItemsControl x:Name="IcManualCampaigns">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                                                        <TextBlock Text="{Binding}" 
                                                                   FontSize="15" 
                                                                   LineHeight="26"
                                                                   Foreground="#334155" 
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Segoe UI Semibold"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        
                                        <Grid Margin="0,8,0,24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="ShieldCheck" Width="20" Height="20" Foreground="#10B981" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="Tüm kampanyalar doğrulanmış ve fiyata yansıtılmıştır." FontSize="13" Foreground="#10B981" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                            
                            <!-- Scroll Fade Indicator -->
                            <Border Height="50" VerticalAlignment="Bottom" IsHitTestVisible="False" CornerRadius="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00FFFFFF" Offset="0"/>
                                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        
                        <!-- Footer -->
                        <Border Grid.Row="2" Background="#F8FAFC" Padding="32,24" CornerRadius="0,0,12,0" BorderThickness="0,1,0,0" BorderBrush="#F1F5F9">
                            <Grid>
                                <TextBlock Text="Bilgi: Kampanya tarihleri stoklarla sınırlıdır." FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" FontWeight="Medium"/>
                                <Button Content="ANLADIM" 
                                        HorizontalAlignment="Right"
                                        Click="BtnCloseManualCampaign_Click"
                                        Background="#1E293B" BorderBrush="#1E293B" Foreground="White"
                                        FontWeight="Black" FontSize="14" Height="46" Padding="32,0"
                                        materialDesign:ButtonAssist.CornerRadius="8"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- Eski Fiyatlar Dialog Overlay -->
        <Grid x:Name="HistoryDialogOverlay" Grid.RowSpan="3" Visibility="Collapsed">
            <Border Background="#221A1A24">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>
            <materialDesign:Card Width="520" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center" UniformCornerRadius="16" Background="White">
                <materialDesign:Card.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.15" Direction="270" ShadowDepth="5"/>
                </materialDesign:Card.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#FFFBEB" Padding="20,16" CornerRadius="16,16,0,0" BorderThickness="0,0,0,1" BorderBrush="#FDE68A">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40" Background="#FEF3C7" CornerRadius="20">
                                    <materialDesign:PackIcon Kind="History" Width="24" Height="24" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Eski Fiyatlar" FontSize="18" FontWeight="Bold" Foreground="#1A1A24"/>
                                    <TextBlock x:Name="TxtHistoryProductName" Text="Ürün Adı" FontSize="13" Foreground="#92400E" TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                </StackPanel>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignIconButton}" 
                                    Width="36" Height="36" Click="BtnCloseHistoryDialog_Click" Foreground="#94A3B8">
                                <materialDesign:PackIcon Kind="Close" Width="22" Height="22"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10" Padding="24,20">
                        <StackPanel x:Name="PnlHistoryContainer">
                            <!-- Items will be generated here in code-behind -->
                        </StackPanel>
                    </ScrollViewer>
                    
                    <Border Grid.Row="2" Background="#FAFAFA" Padding="20,16" CornerRadius="0,0,16,16" BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                        <Grid>
                            <Button Content="Tüm Tarihçeyi Gör" HorizontalAlignment="Left" 
                                    Style="{StaticResource MaterialDesignFlatButton}" 
                                    Foreground="#F59E0B" FontWeight="Bold" Click="BtnGoToFullHistory_Click"/>
                            <Button Content="Kapat" HorizontalAlignment="Right" 
                                    Style="{StaticResource MaterialDesignFlatButton}" 
                                    Foreground="#64748B" FontWeight="SemiBold" Click="BtnCloseHistoryDialog_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </materialDesign:Card>
        </Grid>
        
        <!-- Manuel Fiyat Giriş Overlay -->
        <Grid x:Name="ManualPriceOverlay" Grid.RowSpan="3" Visibility="Collapsed">
            <Border Background="#221A1A24">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>
            <materialDesign:Card Width="350" VerticalAlignment="Center" HorizontalAlignment="Center" UniformCornerRadius="20" Background="White">
                <materialDesign:Card.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.15" Direction="270" ShadowDepth="10"/>
                </materialDesign:Card.Effect>
                <Border Padding="30">
                    <StackPanel>
                        <Border Width="50" Height="50" Background="#FFF8E1" CornerRadius="25" Margin="0,0,0,20">
                            <materialDesign:PackIcon Kind="CashEdit" Width="26" Height="26" Foreground="#FFA000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Fiyat Giriniz" FontSize="20" FontWeight="Bold" Foreground="#1A1A24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Bu ürünün fiyatı 0 olduğu için lütfen manuel fiyat giriniz." FontSize="13" Foreground="#64748B" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,25"/>

                        <TextBox x:Name="TxtManualPrice" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Tutar (₺)"
                                 FontSize="16" FontWeight="SemiBold"
                                 Margin="0,0,0,25"
                                 HorizontalContentAlignment="Center"/>

                        <Button x:Name="BtnConfirmManualPrice" Content="Devam Et" 
                                Style="{StaticResource MaterialDesignFlatButton}" 
                                Foreground="#3949AB" FontWeight="Bold"
                                Click="BtnConfirmManualPrice_Click"/>
                        
                        <Button Content="İptal" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#EF5350" Click="BtnCancelManualPrice_Click"/>
                    </StackPanel>
                </Border>
            </materialDesign:Card>
        </Grid>

        <!-- Sepet Seçim Overlay -->
        <Grid x:Name="CartChoiceOverlay" Grid.RowSpan="3" Visibility="Collapsed">
            <Border Background="#221A1A24">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>
            <materialDesign:Card Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" UniformCornerRadius="20" Background="White">
                <materialDesign:Card.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.15" Direction="270" ShadowDepth="10"/>
                </materialDesign:Card.Effect>
                <Border Padding="30">
                    <StackPanel>
                        <Border Width="50" Height="50" Background="#E8EAF6" CornerRadius="25" Margin="0,0,0,20">
                            <materialDesign:PackIcon Kind="CartPlus" Width="26" Height="26" Foreground="#3949AB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Sepete Ekle" FontSize="20" FontWeight="Bold" Foreground="#1A1A24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Lütfen fiyat tipini seçiniz:" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnSelectParolu" Grid.Column="0" Margin="0,0,8,0" Height="80" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="#3949AB" Foreground="#3949AB"
                                    Click="BtnCartChoice_Click" Tag="Parolu">
                                <StackPanel>
                                    <TextBlock Text="Parolu" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtParoluPrice" Text="0.00 ₺" FontSize="12" Opacity="0.8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnSelectParosuz" Grid.Column="1" Margin="8,0,0,0" Height="80" 
                                    Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="#64748B" Foreground="#64748B"
                                    Click="BtnCartChoice_Click" Tag="Parosuz">
                                <StackPanel>
                                    <TextBlock Text="Parosuz" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtParosuzPrice" Text="0.00 ₺" FontSize="12" Opacity="0.8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Button Content="İptal" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#EF5350" Click="BtnCancelCartChoice_Click"/>
                    </StackPanel>
                </Border>
            </materialDesign:Card>
        </Grid>
        <!-- Valör Ayarları Overlay -->
        <Grid x:Name="ValorSettingsOverlay" Grid.RowSpan="3" Background="#11000000" Visibility="Collapsed">
            <materialDesign:Card Width="960" VerticalAlignment="Center" HorizontalAlignment="Center" UniformCornerRadius="20" Background="White">
                <materialDesign:Card.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.1" Direction="270" ShadowDepth="5"/>
                </materialDesign:Card.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#FBFBFF" Padding="28,20" CornerRadius="20,20,0,0" BorderThickness="0,0,0,1" BorderBrush="#EEF2F6">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="44" Height="44" Background="#FEE2E2" CornerRadius="12">
                                    <materialDesign:PackIcon Kind="CalendarClock" Width="24" Height="24" Foreground="#E02020" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Kategori Bazlı Valör Ayarları" FontSize="18" FontWeight="Bold" Foreground="#1A1A24"/>
                                    <TextBlock Text="Seçtiğiniz valörler o kategoriye ait tüm ürün maliyetlerini otomatik günceller." FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignIconButton}" 
                                    Width="36" Height="36" Click="BtnCloseValorSettings_Click" Foreground="#94A3B8">
                                <materialDesign:PackIcon Kind="Close" Width="22" Height="22"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Content: Kategori Grid Listesi -->
                    <Grid Grid.Row="1" Margin="20,12">
                        <ItemsControl x:Name="IcValorSettings">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" Margin="0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Margin="8,6" Padding="18,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="190"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding CategoryName}" FontSize="14" FontWeight="Bold" Foreground="#1A1A24" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding ValorLabel}" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding ValorChoices}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="Value"
                                                      SelectedValue="{Binding SelectedValorKey, Mode=TwoWay}"
                                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                      materialDesign:TextFieldAssist.UnderlineBrush="#E02020"
                                                      materialDesign:HintAssist.Hint="Valör Seçin"
                                                      Height="42"
                                                      VerticalContentAlignment="Center"
                                                      Padding="12,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Footer -->
                    <Border Grid.Row="2" Background="#FBFBFF" Padding="28,16" CornerRadius="0,0,20,20" BorderThickness="0,1,0,0" BorderBrush="#EEF2F6">
                        <Grid>
                            <TextBlock x:Name="TxtValorSaved" Text="✔ Ayarlar başarıyla güncellendi" 
                                       Foreground="#16A34A" FontWeight="SemiBold" FontSize="14"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Vazgeç" Style="{StaticResource MaterialDesignFlatButton}" 
                                        Foreground="#64748B" FontWeight="SemiBold" Height="40" Padding="20,0" Margin="0,0,12,0"
                                        Click="BtnCloseValorSettings_Click"/>
                                <Button Content="Güncelle ve Kaydet" Background="#E02020" BorderBrush="#E02020" Foreground="White" 
                                        FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="8"
                                        Padding="28,0" Height="42"
                                        Click="BtnSaveValorSettings_Click">
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
