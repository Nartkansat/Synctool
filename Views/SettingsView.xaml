<UserControl x:Class="Synctool.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:Synctool.Views"
             Background="#F5F7FA">
    <UserControl.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource MaterialDesignScrollBarMinimal}" />
    </UserControl.Resources>
    
    <Grid Margin="16,0,16,16">
        <!-- Main Tab Control -->
        <TabControl Style="{StaticResource MaterialDesignTabControl}" 
                    Background="Transparent">
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                    <Setter Property="Padding" Value="16,12"/>
                    <Setter Property="Height" Value="48"/>
                    <Setter Property="Margin" Value="0,0,8,0"/>
                </Style>
            </TabControl.Resources>
            
            <!-- 1. Profil & Güvenlik Sekmesi -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ShieldLockOutline" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Profil &amp; Güvenlik" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" materialDesign:ScrollViewerAssist.IsAutoHideEnabled="True" Margin="0,20,0,0">
                    <StackPanel Margin="0,0,16,0">
                        <!-- Profile Overview - Full Width -->
                        <materialDesign:Card UniformCornerRadius="24" Background="White" Padding="32" Margin="0,0,0,24" materialDesign:ElevationAssist.Elevation="Dp1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="80" Height="80" Background="#EFF6FF" CornerRadius="40">
                                    <materialDesign:PackIcon Kind="AccountTie" Width="40" Height="40" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtProfileName" Text="Yönetici" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                                    <TextBlock x:Name="TxtProfileRole" Text="Admin Yetkisi" FontSize="15" Foreground="#10B981" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                    <TextBlock Text="Sistem Kayıt Tarihi: 27.04.2026" FontSize="13" Foreground="#94A3B8" Margin="0,8,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="2" VerticalAlignment="Top" Background="#ECFDF5" Padding="12,6" CornerRadius="12">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Oturum Aktif" Foreground="#047857" FontWeight="Bold" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </materialDesign:Card>

                        <!-- Security and Info - Two Columns -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Left: Password Form -->
                            <materialDesign:Card Grid.Column="0" UniformCornerRadius="24" Background="White" Padding="32" Margin="0,0,16,0" materialDesign:ElevationAssist.Elevation="Dp1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                        <Border Background="#EEF2FF" Padding="8" CornerRadius="12">
                                            <materialDesign:PackIcon Kind="ShieldLockOutline" Width="24" Height="24" Foreground="#4F46E5" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Güvenlik Ayarları" FontSize="20" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                    </StackPanel>

                                    <TextBlock Text="Mevcut Şifre" FontSize="14" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                    <PasswordBox x:Name="TxtCurrentPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" materialDesign:HintAssist.Hint="Doğrulama için mevcut şifreniz" Margin="0,0,0,24" Height="50"/>

                                    <TextBlock Text="Yeni Şifre" FontSize="14" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                    <PasswordBox x:Name="TxtNewPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" materialDesign:HintAssist.Hint="Yeni şifrenizi girin" Margin="0,0,0,24" Height="50" PasswordChanged="TxtNewPassword_PasswordChanged"/>

                                    <TextBlock Text="Yeni Şifre (Tekrar)" FontSize="14" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                    <PasswordBox x:Name="TxtConfirmPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}" materialDesign:HintAssist.Hint="Yeni şifreyi tekrar girin" Margin="0,0,0,16" Height="50"/>

                                    <TextBlock x:Name="TxtSettingsError" Foreground="#EF4444" FontSize="13" Margin="0,0,0,24" HorizontalAlignment="Left" Visibility="Collapsed" TextWrapping="Wrap"/>

                                    <Button Content="Şifreyi Güvenli Şekilde Güncelle" Foreground="White" Background="#3B82F6" BorderBrush="#3B82F6" Height="50" FontSize="15" FontWeight="Bold" materialDesign:ButtonAssist.CornerRadius="12" Click="BtnUpdatePassword_Click"/>
                                </StackPanel>
                            </materialDesign:Card>

                            <!-- Right: Info Panels -->
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <materialDesign:Card UniformCornerRadius="24" Background="#F8FAFC" Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp0">
                                    <StackPanel>
                                        <TextBlock Text="Şifre Standartları" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="0,0,0,16"/>
                                        <TextBlock Text="Yeni şifrenizin aşağıdaki güvenlik standartlarını karşılaması gerekmektedir:" FontSize="13" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,20"/>
                                        
                                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                            <materialDesign:PackIcon x:Name="IconSetLength" Kind="CircleOutline" Foreground="#94A3B8" Width="18" Height="18" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtSetLength" Text="En az 8 karakter uzunluğunda" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                            <materialDesign:PackIcon x:Name="IconSetUpper" Kind="CircleOutline" Foreground="#94A3B8" Width="18" Height="18" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtSetUpper" Text="En az 1 büyük harf" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                                            <materialDesign:PackIcon x:Name="IconSetLower" Kind="CircleOutline" Foreground="#94A3B8" Width="18" Height="18" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtSetLower" Text="En az 1 küçük harf" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon x:Name="IconSetSymbol" Kind="CircleOutline" Foreground="#94A3B8" Width="18" Height="18" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtSetSymbol" Text="En az 1 sembol (özel karakter)" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card UniformCornerRadius="24" Background="#EEF2FF" Padding="24" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp0">
                                    <StackPanel>
                                        <TextBlock Text="Hesap Durumu" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="0,0,0,12"/>
                                        <TextBlock Text="Hesabınız şu anda en yüksek yetki seviyesinde ve tam koruma altındadır." FontSize="13" Foreground="#4F46E5" TextWrapping="Wrap" LineHeight="20"/>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card UniformCornerRadius="24" Background="#F1F5F9" Padding="24" materialDesign:ElevationAssist.Elevation="Dp0">
                                    <StackPanel>
                                        <TextBlock Text="Lisans Bilgisi" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="0,0,0,12"/>
                                        <TextBlock Text="Hesabınız şu lisans anahtarı ile tanımlıdır:" FontSize="13" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="White" CornerRadius="8" Padding="12,8" BorderThickness="1" BorderBrush="#CBD5E1">
                                                <TextBlock x:Name="TxtLicenseKey" Text="••••-••••-••••-••••" FontSize="13" Foreground="#334155" FontWeight="SemiBold" FontFamily="Consolas" VerticalAlignment="Center">
                                                    <TextBlock.Effect>
                                                        <BlurEffect x:Name="BlurEffectLicense" Radius="5"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                            </Border>
                                            <Button Grid.Column="1" x:Name="BtnShowLicense" Content="Göster" Margin="10,0,0,0"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#3B82F6" BorderBrush="#CBD5E1"
                                                    materialDesign:ButtonAssist.CornerRadius="8" Height="38" Padding="16,0" Click="BtnShowLicense_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </materialDesign:Card>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2. Sözleşme Yönetimi (Admin) -->
            <TabItem x:Name="TabAgreementManagement" Visibility="Collapsed">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentCheckOutline" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Sözleşme Yönetimi" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Agreement History List Sidebar -->
                    <materialDesign:Card Grid.Column="0" UniformCornerRadius="24" Background="White" Padding="20" Margin="0,0,20,0" materialDesign:ElevationAssist.Elevation="Dp1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Sözleşme Sürümleri" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="4,0,0,16"/>
                            
                            <Button Grid.Row="1" x:Name="BtnNewAgreementInit" Margin="0,0,0,16"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    BorderThickness="0"
                                    materialDesign:ButtonAssist.CornerRadius="12" Height="44" Click="BtnNewAgreementInit_Click">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#1D4ED8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Yeni Sürüm Yayınla" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                            
                            <!-- Custom Agreement List -->
                            <ListBox Grid.Row="2" x:Name="LstAgreements" Background="Transparent" BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionChanged="LstAgreements_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder" Background="#F8FAFC" CornerRadius="14" Padding="14,10" BorderThickness="1" BorderBrush="#E2E8F0">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF"/>
                                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#3B82F6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#93C5FD"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Icon -->
                                            <Border Grid.Column="0" Width="36" Height="36" Background="#EEF2FF" CornerRadius="10" Margin="0,0,12,0">
                                                <materialDesign:PackIcon Kind="FileDocumentOutline" Width="18" Height="18" Foreground="#4F46E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <!-- Version & Date -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Version}" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            
                                            <!-- Badge -->
                                            <Border Grid.Column="2" x:Name="BadgeBorder" CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
                                                <TextBlock x:Name="BadgeText" Text="Eski" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                <Setter TargetName="BadgeBorder" Property="Background" Value="#ECFDF5"/>
                                                <Setter TargetName="BadgeText" Property="Foreground" Value="#10B981"/>
                                                <Setter TargetName="BadgeText" Property="Text" Value="Aktif"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsLatest}" Value="False">
                                                <Setter TargetName="BadgeBorder" Property="Background" Value="#F1F5F9"/>
                                                <Setter TargetName="BadgeText" Property="Foreground" Value="#64748B"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Right Column: Details Pane (Normal View) or Editor Pane (Publish View) -->
                    <Grid Grid.Column="1">
                        <!-- Panel A: Normal View with side-by-side selected agreement & consents -->
                        <Grid x:Name="PanelNormalAgreementView" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" MinWidth="380"/>
                                <ColumnDefinition Width="1.8*" MinWidth="500"/>
                            </Grid.ColumnDefinitions>

                            <!-- Middle Pane: Agreement Text Display -->
                            <materialDesign:Card Grid.Column="0" UniformCornerRadius="24" Background="White" Padding="24" Margin="0,0,20,0" materialDesign:ElevationAssist.Elevation="Dp1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Header Info -->
                                    <Grid Grid.Row="0" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" Background="#EEF2FF" CornerRadius="12" Margin="0,0,12,0">
                                            <materialDesign:PackIcon Kind="FileDocumentOutline" Width="20" Height="20" Foreground="#4F46E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="TxtSelectedVersionTitle" Text="Sözleşme Detayları" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock x:Name="TxtSelectedVersionSub" Text="Seçilen sürüm metni." FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="16"  BorderThickness="1" BorderBrush="#E2E8F0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                                            <TextBlock x:Name="TxtSelectedAgreementContent" Margin="15" TextWrapping="Wrap" FontSize="14" Foreground="#334155" LineHeight="22"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </materialDesign:Card>

                            <!-- Right Pane: User Acceptance Status List -->
                            <materialDesign:Card Grid.Column="1" UniformCornerRadius="24" Background="White" Padding="24" materialDesign:ElevationAssist.Elevation="Dp1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Header -->
                                    <Grid Grid.Row="0" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" Background="#EFF6FF" CornerRadius="12" Margin="0,0,12,0">
                                            <materialDesign:PackIcon Kind="AccountCheckOutline" Width="20" Height="20" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Kullanıcı Onay Durumu" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="Kullanıcıların bu sürümü kabul etme durumları." FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <!-- Metric Cards Grid -->
                                    <Grid Grid.Row="1" Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Card 1: Accepted -->
                                        <Border Grid.Column="0" Background="#ECFDF5" CornerRadius="16" Padding="16,12" Margin="0,0,8,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="40" Height="40" Background="#D1FAE5" CornerRadius="12">
                                                    <materialDesign:PackIcon Kind="CheckCircleOutline" Width="22" Height="22" Foreground="#059669" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Kabul Eden" FontSize="12" Foreground="#047857" FontWeight="Medium"/>
                                                    <TextBlock x:Name="TxtAgreementAcceptedCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="#065F46"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Card 2: Pending -->
                                        <Border Grid.Column="1" Background="#FEF2F2" CornerRadius="16" Padding="16,12" Margin="8,0,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="40" Height="40" Background="#FEE2E2" CornerRadius="12">
                                                    <materialDesign:PackIcon Kind="ClockOutline" Width="22" Height="22" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Kabul Etmeyen" FontSize="12" Foreground="#991B1B" FontWeight="Medium"/>
                                                    <TextBlock x:Name="TxtAgreementPendingCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="#991B1B"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <!-- Search Box Row (Premium Custom Search Box) -->
                                    <Border Grid.Row="2" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="12" Background="White" Height="42" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <materialDesign:PackIcon Kind="Magnify" Foreground="#94A3B8" Width="20" Height="20" Margin="12,0,8,0" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" x:Name="TxtAgreementConsentSearch" 
                                                     Background="Transparent" BorderThickness="0" 
                                                     VerticalAlignment="Center" FontSize="14" Foreground="#1E293B"
                                                     materialDesign:HintAssist.Hint="Kullanıcı veya bayiye göre ara..."
                                                     materialDesign:HintAssist.Foreground="#94A3B8"
                                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                                     TextChanged="TxtAgreementConsentSearch_TextChanged"/>
                                        </Grid>
                                    </Border>

                                    <!-- Consents Table -->
                                    <DataGrid Grid.Row="3" x:Name="GridAgreementConsents" AutoGenerateColumns="False" IsReadOnly="True" 
                                              SelectionMode="Single" Background="Transparent" BorderThickness="0"
                                              CanUserAddRows="False" GridLinesVisibility="Horizontal" MinHeight="300"
                                              HeadersVisibility="Column" HorizontalGridLinesBrush="#E2E8F0"
                                              VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                <Setter Property="Foreground" Value="#475569"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Height" Value="40"/>
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            </Style>
                                            <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                                <Setter Property="Height" Value="48"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#EFF6FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                                <Setter Property="Padding" Value="12,8"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="KULLANICI" Binding="{Binding Username}" Width="1.2*" ElementStyle="{StaticResource MaterialDesignBody1TextBlock}"/>
                                            <DataGridTextColumn Header="BAYİ ADI" Binding="{Binding DealerName}" Width="1.5*" ElementStyle="{StaticResource MaterialDesignBody1TextBlock}"/>
                                            <DataGridTemplateColumn Header="DURUM" Width="1.1*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="ConsentBadge" Padding="8,4" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                            <TextBlock x:Name="ConsentText" Text="{Binding IsAcceptedLatest}" FontSize="11" FontWeight="Bold"/>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsAccepted}" Value="True">
                                                                <Setter TargetName="ConsentBadge" Property="Background" Value="#D1FAE5"/>
                                                                <Setter TargetName="ConsentText" Property="Foreground" Value="#065F46"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsAccepted}" Value="False">
                                                                <Setter TargetName="ConsentBadge" Property="Background" Value="#FEE2E2"/>
                                                                <Setter TargetName="ConsentText" Property="Foreground" Value="#991B1B"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="ONAY TARİHİ" Binding="{Binding AcceptedAtString}" Width="1.4*"/>
                                            <DataGridTextColumn Header="IP ADRESİ" Binding="{Binding IpAddress}" Width="1*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>

                        <!-- Panel B: Publish New Agreement Form -->
                        <materialDesign:Card x:Name="PanelPublishAgreement" UniformCornerRadius="24" Background="White" Padding="28" materialDesign:ElevationAssist.Elevation="Dp1" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Header -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#DBEAFE" Padding="8" CornerRadius="12">
                                            <materialDesign:PackIcon Kind="FilePlusOutline" Width="24" Height="24" Foreground="#2563EB" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Yeni Sözleşme Yayınla" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Yayınlanan yeni sözleşme sürümü, tüm kullanıcılara bir sonraki girişlerinde onaylanmak üzere zorunlu olarak sunulacaktır." FontSize="13" Foreground="#64748B" Margin="0,8,0,0"/>
                                </StackPanel>
                                
                                <!-- Editor Area -->
                                <Grid Grid.Row="1" Margin="0,0,0,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="Sürüm Versiyonu" FontSize="14" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                    <TextBox Grid.Row="1" x:Name="TxtAgreementVersion" Width="150" HorizontalAlignment="Left" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Örn: v1.1" Padding="12,10" FontSize="14" Foreground="#1E293B" FontWeight="Bold" Margin="0,0,0,16"/>
                                    
                                    <TextBlock Grid.Row="2" Text="Sözleşme Metni" FontSize="14" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                    <Border Grid.Row="3" Background="#F1F5F9" CornerRadius="16" BorderThickness="1" BorderBrush="#E2E8F0">
                                        <TextBox x:Name="TxtAgreementContent"
                                                 Style="{StaticResource MaterialDesignTextBox}"
                                                 materialDesign:HintAssist.Hint="Kullanıcı sözleşmesi metnini buraya yazın..."
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Segoe UI" FontSize="15"
                                                 VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                 BorderThickness="0" Background="Transparent"
                                                 Padding="20"/>
                                    </Border>
                                </Grid>
                                
                                <!-- Action Buttons -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" x:Name="BtnCancelPublish" Content="Vazgeç ve Listeye Dön" Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="#64748B" BorderBrush="#CBD5E1" materialDesign:ButtonAssist.CornerRadius="10" Height="42" Click="BtnCancelPublish_Click"/>
                                    
                                    <Button Grid.Column="2" x:Name="BtnSaveAgreement" Content="Sözleşmeyi Yayınla" Background="#2563EB" BorderBrush="#2563EB" Foreground="White"
                                            FontWeight="Bold" Height="42" materialDesign:ButtonAssist.CornerRadius="10" Click="BtnSaveAgreement_Click"/>
                                </Grid>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 3. Veri Yönetimi (Admin) -->
            <TabItem x:Name="TabDataManagement" Visibility="Collapsed">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DatabaseRefresh" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Veri Yönetimi" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,20,0,0">
                    <materialDesign:Card UniformCornerRadius="24" Background="White" Padding="32" materialDesign:ElevationAssist.Elevation="Dp2" VerticalAlignment="Top" HorizontalAlignment="Left" MinWidth="600">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                <Border Background="#FEE2E2" Padding="8" CornerRadius="12">
                                    <materialDesign:PackIcon Kind="DatabaseRefresh" Width="28" Height="28" Foreground="#DC2626" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Sistem Verilerini Sıfırlama" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </StackPanel>
                            
                            <Border Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#DC2626" Width="24" Height="24" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dikkat: Seçili tablolar kalıcı olarak sıfırlanır (TRUNCATE). Tüm veriler silinir ve ID'ler baştan başlar. İşlem geri alınamaz!" 
                                             FontSize="14" Foreground="#991B1B" Margin="12,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="500"/>
                                </StackPanel>
                            </Border>

                            <CheckBox x:Name="ChkSelectAll" Content="Tüm Tabloları Seç" FontWeight="Bold" FontSize="15" Foreground="#1E293B" Margin="0,0,0,16" 
                                      Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Unchecked"/>
                            
                            <Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,20"/>

                            <Grid Margin="12,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <CheckBox x:Name="ChkCostCalculations" Content="Maliyet Hesaplamaları" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                    <CheckBox x:Name="ChkOlizCampaigns" Content="Oliz Kampanyaları" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                    <CheckBox x:Name="ChkKeaProducts" Content="KEA Ürünleri" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <CheckBox x:Name="ChkWhiteGoodsProducts" Content="Beyaz Eşya Ürünleri" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                    <CheckBox x:Name="ChkHistoricalKea" Content="KEA Tarihçe" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                    <CheckBox x:Name="ChkHistoricalWhiteGoods" Content="Beyaz Eşya Tarihçe" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <CheckBox x:Name="ChkManualCampaigns" Content="Manuel Kampanyalar" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                    <CheckBox x:Name="ChkManualCampaignProducts" Content="Manuel Kampanya Ürünleri" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                    <CheckBox x:Name="ChkUploadedFiles" Content="Yüklenen Dosyalar" FontSize="15" Foreground="#475569" Margin="0,8"/>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="BtnResetTables" Content="Seçili Tabloları Sıfırla" 
                                    Margin="0,32,0,0" Height="50" Background="#DC2626" BorderBrush="#DC2626" Foreground="White" 
                                    FontWeight="Bold" FontSize="15" materialDesign:ButtonAssist.CornerRadius="12"
                                    Click="BtnResetTables_Click" HorizontalAlignment="Right" Width="250"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
            
            <!-- 4. Kullanım Kılavuzu (Admin & User) -->
            <TabItem x:Name="TabUserGuide" Visibility="Collapsed">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BookOpenOutline" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Kullanım Kılavuzu" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,20,0,0">
                    <materialDesign:Card UniformCornerRadius="24" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header -->
                            <Border Background="#F8FAFC" CornerRadius="24,24,0,0" Padding="32,24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#FEF3C7" Padding="8" CornerRadius="12">
                                                <materialDesign:PackIcon Kind="BookOpenOutline" Width="28" Height="28" Foreground="#D97706" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Uygulama Kullanım Kılavuzu" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="16,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Uygulamanın doğru ve güvenli kullanımı için hazırlanan kılavuz ve yönergeler." FontSize="14" Foreground="#64748B" Margin="0,12,0,0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Edit Mode Toggle Button (Admin only) -->
                                        <Button x:Name="BtnEditUserGuideToggle" Content="Düzenle" Margin="0,0,12,0"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#D97706" BorderBrush="#D97706" 
                                                FontWeight="Bold" Height="42" materialDesign:ButtonAssist.CornerRadius="10" 
                                                Click="BtnEditUserGuideToggle_Click"/>
                                        
                                        <!-- Save Button (Admin only, visible in edit mode) -->
                                        <Button x:Name="BtnSaveUserGuide" Content="Kılavuzu Kaydet" Visibility="Collapsed"
                                                Background="#D97706" BorderBrush="#D97706" Foreground="White" FontWeight="Bold" Height="42"
                                                materialDesign:ButtonAssist.CornerRadius="10" Click="BtnSaveUserGuide_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Content Area -->
                            <Grid Grid.Row="1" Margin="32,0,32,32">
                                <!-- View Panel (WebBrowser) -->
                                <Border x:Name="BorderUserGuideView" Background="White" CornerRadius="16" BorderThickness="1" BorderBrush="#E2E8F0" Height="480" Visibility="Visible">
                                    <WebBrowser x:Name="WebUserGuideView" Margin="4"/>
                                </Border>

                                <!-- Edit Panel (TextBox) -->
                                <Border x:Name="BorderUserGuideEdit" Background="#F1F5F9" CornerRadius="16" BorderThickness="1" BorderBrush="#E2E8F0" Height="480" Visibility="Collapsed">
                                    <TextBox x:Name="TxtUserGuideContent"
                                             Style="{StaticResource MaterialDesignTextBox}"
                                             materialDesign:HintAssist.Hint="Kullanım kılavuzu içeriğini buraya yazın..."
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             FontFamily="Segoe UI" FontSize="15"
                                             VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                             BorderThickness="0" Background="Transparent"
                                             Padding="24"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
            

        </TabControl>

        <!-- Modern Premium Toast Notification (Restored) -->
        <materialDesign:Card x:Name="ToastCard" Visibility="Collapsed" Opacity="0"
                            VerticalAlignment="Top" HorizontalAlignment="Right" 
                            Margin="0,30,30,0" UniformCornerRadius="16" 
                            Background="White" Width="360"
                            materialDesign:ElevationAssist.Elevation="Dp4">
            <materialDesign:Card.RenderTransform>
                <TranslateTransform X="50"/>
            </materialDesign:Card.RenderTransform>
            <Border BorderBrush="#10B981" BorderThickness="4,0,0,0" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Width="36" Height="36" Background="#ECFDF5" CornerRadius="18">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#10B981" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="16,0">
                        <TextBlock Text="Başarılı!" FontWeight="Bold" FontSize="15" Foreground="#1E293B"/>
                        <TextBlock x:Name="TxtToastMessage" Text="İşlem başarıyla tamamlandı." 
                                 Foreground="#64748B" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24" 
                            Click="BtnCloseToast_Click" Foreground="#94A3B8" VerticalAlignment="Top">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>
        </materialDesign:Card>

        <!-- Custom Modern Alert Overlay (Glassmorphism) -->
        <Grid x:Name="AlertOverlay" Visibility="Collapsed" Grid.RowSpan="2" Margin="-32">
            <Border Background="#660F172A">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>
            <Grid Background="#11FFFFFF">
                <materialDesign:Card Width="460" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="24" Background="White" materialDesign:ElevationAssist.Elevation="Dp8">
                    <Border Padding="32">
                        <StackPanel>
                            <Border x:Name="BorderAlertIcon" Width="64" Height="64" Background="#FEF2F2" CornerRadius="32" Margin="0,0,0,24">
                                <materialDesign:PackIcon x:Name="IconAlert" Kind="AlertCircleOutline" Width="36" Height="36" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock x:Name="TxtAlertTitle" Text="Tablo Sıfırlama Onayı" FontSize="22" FontWeight="Bold" 
                                       Foreground="#1E293B" Margin="0,0,0,12" HorizontalAlignment="Center" TextAlignment="Center"/>
                            
                            <TextBlock x:Name="TxtAlertMessage" Text="Seçili tablolar tamamen sıfırlanacaktır. Bu işlem geri alınamaz. Devam etmek istiyor musunuz?" FontSize="15" 
                                       Foreground="#64748B" TextWrapping="Wrap" LineHeight="24" TextAlignment="Center" Margin="0,0,0,32"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnCancelAlert" Content="Vazgeç" Grid.Column="0" Margin="0,0,8,0"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#64748B" BorderBrush="#CBD5E1"
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="SemiBold"
                                        Click="BtnCancelAlert_Click"/>
                                <Button x:Name="BtnConfirmAction" Content="Evet, Sıfırla" Grid.Column="1" Margin="8,0,0,0"
                                        Foreground="White" Background="#DC2626" BorderBrush="#DC2626" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="Bold"
                                        Click="BtnConfirmAlert_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- Custom Password Confirmation Overlay (Glassmorphism) -->
        <Grid x:Name="PasswordConfirmOverlay" Visibility="Collapsed" Grid.RowSpan="2" Margin="-32">
            <Border Background="#660F172A">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>
            <Grid Background="#11FFFFFF">
                <materialDesign:Card Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="24" Background="White" materialDesign:ElevationAssist.Elevation="Dp8">
                    <Border Padding="32">
                        <StackPanel>
                            <Border Width="64" Height="64" Background="#FEE2E2" CornerRadius="32" Margin="0,0,0,24">
                                <materialDesign:PackIcon Kind="ShieldKeyOutline" Width="36" Height="36" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock Text="Güvenlik Doğrulaması" FontSize="22" FontWeight="Bold" 
                                       Foreground="#1E293B" Margin="0,0,0,12" HorizontalAlignment="Center" TextAlignment="Center"/>
                            
                            <TextBlock Text="Kritik sistem verilerini sıfırlamak üzeresiniz. Lütfen yönetici şifrenizi girerek işlemi onaylayın." FontSize="14" 
                                       Foreground="#64748B" TextWrapping="Wrap" LineHeight="20" TextAlignment="Center" Margin="0,0,0,24"/>

                            <PasswordBox x:Name="TxtConfirmResetPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Yönetici Şifreniz" Margin="0,0,0,16" Height="50" KeyDown="TxtConfirmResetPassword_KeyDown"/>

                            <TextBlock x:Name="TxtConfirmResetPasswordError" Foreground="#EF4444" FontSize="13" Margin="0,0,0,16" 
                                       HorizontalAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnCancelPasswordConfirm" Content="İptal" Grid.Column="0" Margin="0,0,8,0"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#64748B" BorderBrush="#CBD5E1"
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="SemiBold"
                                        Click="BtnCancelPasswordConfirm_Click"/>
                                <Button x:Name="BtnVerifyPasswordAndReset" Content="Doğrula ve Sıfırla" Grid.Column="1" Margin="8,0,0,0"
                                        Foreground="White" Background="#DC2626" BorderBrush="#DC2626" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="Bold"
                                        Click="BtnVerifyPasswordAndReset_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- License Password Confirmation Overlay (Glassmorphism) -->
        <Grid x:Name="LicenseVerifyOverlay" Visibility="Collapsed" Grid.RowSpan="2" Margin="-32">
            <Border Background="#660F172A">
                <Border.Effect>
                    <BlurEffect Radius="10"/>
                </Border.Effect>
            </Border>
            <Grid Background="#11FFFFFF">
                <materialDesign:Card Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="24" Background="White" materialDesign:ElevationAssist.Elevation="Dp8">
                    <Border Padding="32">
                        <StackPanel>
                            <Border Width="64" Height="64" Background="#EFF6FF" CornerRadius="32" Margin="0,0,0,24">
                                <materialDesign:PackIcon Kind="KeyVariant" Width="36" Height="36" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock Text="Lisans Gösterimi Doğrulaması" FontSize="20" FontWeight="Bold" 
                                       Foreground="#1E293B" Margin="0,0,0,12" HorizontalAlignment="Center" TextAlignment="Center"/>
                            
                            <TextBlock Text="Lisans anahtarınızı görüntülemek için lütfen mevcut şifrenizi girin." FontSize="14" 
                                       Foreground="#64748B" TextWrapping="Wrap" LineHeight="20" TextAlignment="Center" Margin="0,0,0,24"/>

                            <PasswordBox x:Name="TxtLicenseVerifyPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Şifreniz" Margin="0,0,0,16" Height="50" KeyDown="TxtLicenseVerifyPassword_KeyDown"/>

                            <TextBlock x:Name="TxtLicenseVerifyPasswordError" Foreground="#EF4444" FontSize="13" Margin="0,0,0,16" 
                                       HorizontalAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap" TextAlignment="Center"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnCancelLicenseVerify" Content="İptal" Grid.Column="0" Margin="0,0,8,0"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#64748B" BorderBrush="#CBD5E1"
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="SemiBold"
                                        Click="BtnCancelLicenseVerify_Click"/>
                                <Button x:Name="BtnConfirmLicenseVerify" Content="Doğrula ve Göster" Grid.Column="1" Margin="8,0,0,0"
                                        Foreground="White" Background="#3B82F6" BorderBrush="#3B82F6" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="Bold"
                                        Click="BtnConfirmLicenseVerify_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
