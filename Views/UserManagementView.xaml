<UserControl x:Class="Synctool.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Synctool.Converters"
             Background="#F4F6F8" Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <converters:RoleToColorConverter x:Key="RoleToColorConverter"/>
        <converters:ActiveToColorConverter x:Key="ActiveToColorConverter"/>
        <converters:ActiveToTextConverter x:Key="ActiveToTextConverter"/>
        <converters:BooleanToIconConverter x:Key="BooleanToIconConverter"/>
        <converters:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
        <converters:BooleanToTextConverter x:Key="BooleanToTextConverter"/>
    </UserControl.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="50" Height="50" Background="#FFEAEA" CornerRadius="15">
                    <materialDesign:PackIcon Kind="AccountSettingsOutline" Width="28" Height="28" Foreground="#E02020" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="20,0,0,0">
                    <TextBlock Text="Kullanıcı Yönetimi" FontSize="28" FontWeight="Bold" Foreground="#1A1A24"/>
                    <TextBlock Text="Sistem erişim yetkilerini ve lisans anahtarlarını kontrol edin" FontSize="14" Foreground="#7E84A3" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Click="BtnOpenNotificationDialog_Click" Margin="0,0,15,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="12"
                        Height="48" Padding="25,0" Background="#3949AB" Foreground="White" BorderBrush="#3949AB">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BellPlusOutline" Foreground="White" Width="22" Height="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Bildirim Gönder" FontSize="15" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Button Click="BtnAddUser_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="12"
                        Height="48" Padding="25,0" Background="#E02020" Foreground="White" BorderBrush="#E02020">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Foreground="White" Width="22" Height="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Yeni Kullanıcı" FontSize="15" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Modern Filter Bar -->
        <Border Grid.Row="1" Background="White" CornerRadius="18" Padding="25,12" Margin="0,0,0,25">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.03" Direction="270" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Search" Foreground="#7E84A3" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBox x:Name="TxtSearch" Width="300" materialDesign:HintAssist.Hint="Kullanıcı adına veya yetkiye göre filtrele..." 
                             BorderThickness="0" materialDesign:TextFieldAssist.DecorationVisibility="Collapsed" 
                             VerticalAlignment="Center" FontSize="14" Foreground="#1A1A24"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Premium Table Container -->
        <materialDesign:Card Grid.Row="2" UniformCornerRadius="20" Background="White" Padding="15">
            <DataGrid x:Name="GridUsers" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionMode="Single" Background="Transparent" BorderThickness="0"
                      CanUserAddRows="False" GridLinesVisibility="None"
                      HeadersVisibility="Column" HorizontalGridLinesBrush="#F8F9FB">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#7E84A3"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Height" Value="50"/>
                        <Setter Property="Padding" Value="15,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F1F3F9"/>
                    </Style>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Setter Property="Height" Value="65"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#F8F9FB"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Kullanıcı Bilgisi" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <Border Width="36" Height="36" Background="#F1F3F9" CornerRadius="18">
                                        <materialDesign:PackIcon Kind="Account" Foreground="#7E84A3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding Username}" FontWeight="Bold" FontSize="15" 
                                               Foreground="#1A1A24" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTemplateColumn Header="Yetki" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Role, Converter={StaticResource RoleToColorConverter}}" 
                                        Padding="12,5" CornerRadius="10" HorizontalAlignment="Left" 
                                        VerticalAlignment="Center" Margin="0,0">
                                    <TextBlock Text="{Binding Role}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Lisans Anahtarı" Binding="{Binding LicenseKey}" Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Son Aktivite" Binding="{Binding LastLoginDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="180">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#7E84A3"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    
                    <DataGridTemplateColumn Header="Cihaz" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="{Binding IsActivated, Converter={StaticResource BooleanToIconConverter}}" 
                                                           Foreground="{Binding IsActivated, Converter={StaticResource BooleanToColorConverter}}"
                                                           Width="18" Height="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding IsActivated, Converter={StaticResource BooleanToTextConverter}}" 
                                               Margin="8,0,0,0" FontSize="13" VerticalAlignment="Center" 
                                               Foreground="{Binding IsActivated, Converter={StaticResource BooleanToColorConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Hesap Durumu" Width="170">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBadge" Padding="10,4" CornerRadius="8" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="StatusIcon" Width="16" Height="16" VerticalAlignment="Center" Margin="2,0,6,0"/>
                                        <TextBlock x:Name="StatusText" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="#FEE2E2"/>
                                        <Setter TargetName="StatusIcon" Property="Kind" Value="LockOutline"/>
                                        <Setter TargetName="StatusIcon" Property="Foreground" Value="#DC2626"/>
                                        <Setter TargetName="StatusText" Property="Text" Value="Askıya Alındı"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#DC2626"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsLocked}" Value="False">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="#ECFDF5"/>
                                        <Setter TargetName="StatusIcon" Property="Kind" Value="CheckCircleOutline"/>
                                        <Setter TargetName="StatusIcon" Property="Foreground" Value="#10B981"/>
                                        <Setter TargetName="StatusText" Property="Text" Value="Aktif"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Aksiyon"  Width="200">
                        <DataGridTemplateColumn.HeaderStyle>
                            <!-- Material Design'ın orijinal stilini temel alıyoruz -->
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <!-- Eğer margin/padding gerekiyorsa -->
                                <Setter Property="Padding" Value="10,0,10,0" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            Width="36" Height="36" Margin="0,0,2,0"
                                            ToolTip="Düzenle" Click="BtnEditUser_Click"
                                            Foreground="#3949AB">
                                        <materialDesign:PackIcon Kind="PencilOutline" Width="20" Height="20"/>
                                    </Button>
                                    <Button x:Name="BtnUnlock" Style="{StaticResource MaterialDesignIconButton}" 
                                            Width="36" Height="36" Margin="0,0,2,0"
                                            ToolTip="Kilidi Kaldır" Click="BtnUnlockUser_Click"
                                            Foreground="#4CAF50" Visibility="Collapsed">
                                        <materialDesign:PackIcon Kind="LockOpenOutline" Width="20" Height="20"/>
                                    </Button>
                                    <Button x:Name="BtnLock" Style="{StaticResource MaterialDesignIconButton}" 
                                            Width="36" Height="36" Margin="0,0,2,0"
                                            ToolTip="Hesabı Askıya Al" Click="BtnLockUser_Click"
                                            Foreground="#F44336" Visibility="Visible">
                                        <materialDesign:PackIcon Kind="LockOutline" Width="20" Height="20"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            Width="36" Height="36" Margin="0,0,2,0"
                                            ToolTip="Oturumu Sıfırla" Click="BtnResetSession_Click"
                                            Foreground="#FF9800">
                                        <materialDesign:PackIcon Kind="ShieldRefreshOutline" Width="20" Height="20"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                                            Width="36" Height="36"
                                            ToolTip="Cihazı Sıfırla" Click="BtnResetDevice_Click"
                                            Foreground="#E91E63">
                                        <materialDesign:PackIcon Kind="CellphoneLock" Width="20" Height="20"/>
                                    </Button>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                        <Setter TargetName="BtnUnlock" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="BtnLock" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- Yeni Kullanıcı Dialog Overlay -->
        <Grid x:Name="DialogOverlay" Grid.RowSpan="3" Visibility="Collapsed">
            <Border Background="#111A1A24">
                <Border.Effect>
                    <BlurEffect Radius="15"/>
                </Border.Effect>
            </Border>
            <Grid Background="#22FFFFFF">
                <materialDesign:Card Width="680" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="25" Background="White">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.15" Direction="270" ShadowDepth="10"/>
                    </materialDesign:Card.Effect>
                    <Border Padding="40">
                        <StackPanel>
                            <!-- Header Icon and Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24" HorizontalAlignment="Left">
                                <Border Width="50" Height="50" Background="#FFEAEA" CornerRadius="16" Margin="0,0,16,0">
                                    <materialDesign:PackIcon Kind="AccountPlusOutline" Width="26" Height="26" Foreground="#E02020" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Yeni Kullanıcı Ekle" FontSize="22" FontWeight="Bold" Foreground="#1A1A24"/>
                                    <TextBlock Text="Sistem erişimi için yeni bir kullanıcı profilini tanımlayın" FontSize="13" Foreground="#7E84A3" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#F1F5F9" Margin="0,0,0,24"/>

                            <!-- Row 1: Kullanıcı Adı & E-Posta Adresi (2 Columns) -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="AccountOutline" Width="18" Height="18" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Kullanıcı Adı" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtNewUsername" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Örn: admin" Height="48"
                                             materialDesign:TextFieldAssist.HasClearButton="True"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="EmailOutline" Width="18" Height="18" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="E-Posta Adresi" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtNewEmail" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="ornek@arcelik.com" Height="48"
                                             materialDesign:TextFieldAssist.HasClearButton="True"/>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Bayi Adı & Yetki Rolü (2 Columns) -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="StorefrontOutline" Width="18" Height="18" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Bayi Adı" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtNewDealerName" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Örn: Merkez Bayi" Height="48"
                                             materialDesign:TextFieldAssist.HasClearButton="True"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="ShieldAccountOutline" Width="18" Height="18" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Yetki Rolü" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ComboBox x:Name="CmbRole" Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="48">
                                        <ComboBoxItem Content="User" IsSelected="True"/>
                                        <ComboBoxItem Content="Admin"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Row 3: Şifre & Şifre (Tekrar) (2 Columns) -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="LockOutline" Width="18" Height="18" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Şifre" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Height="48">
                                        <PasswordBox x:Name="TxtNewPassword" Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                     materialDesign:HintAssist.Hint="Şifrenizi belirleyin"
                                                     Padding="16,0,45,0" VerticalContentAlignment="Center" Height="48"
                                                     PasswordChanged="TxtNewPassword_PasswordChanged"/>
                                        <TextBox x:Name="TxtNewPasswordVisible" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:HintAssist.Hint="Şifrenizi belirleyin"
                                                 Visibility="Collapsed" Padding="16,0,45,0" VerticalContentAlignment="Center" Height="48"
                                                 TextChanged="TxtNewPasswordVisible_TextChanged"/>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Focusable="False"
                                                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                                Width="30" Height="30" Click="BtnAddShowPassword_Click">
                                            <materialDesign:PackIcon x:Name="IconAddShowPassword" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="LockCheckOutline" Width="18" Height="18" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Şifre (Tekrar)" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Height="48">
                                        <PasswordBox x:Name="TxtNewPasswordConfirm" Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                     materialDesign:HintAssist.Hint="Şifreyi tekrar girin"
                                                     Padding="16,0,45,0" VerticalContentAlignment="Center" Height="48"/>
                                        <TextBox x:Name="TxtNewPasswordConfirmVisible" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:HintAssist.Hint="Şifreyi tekrar girin"
                                                 Visibility="Collapsed" Padding="16,0,45,0" VerticalContentAlignment="Center" Height="48"/>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Focusable="False"
                                                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                                Width="30" Height="30" Click="BtnAddShowPasswordConfirm_Click">
                                            <materialDesign:PackIcon x:Name="IconAddShowPasswordConfirm" Kind="EyeOffOutline" Width="20" Height="20" Foreground="#94A3B8"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- Password Strength Validator Panel -->
                            <Border x:Name="PassValidatorPanel" Background="#F8FAFC" CornerRadius="16" BorderThickness="1" BorderBrush="#E2E8F0" Padding="16,12" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Şifre Güvenlik Standartları" FontSize="13" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,8"/>
                                    <UniformGrid Columns="2">
                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                            <materialDesign:PackIcon x:Name="IconNewLength" Kind="CircleOutline" Width="16" Height="16" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtNewLength" Text="En az 8 karakter" FontSize="12" Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                            <materialDesign:PackIcon x:Name="IconNewUpper" Kind="CircleOutline" Width="16" Height="16" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtNewUpper" Text="En az 1 büyük harf" FontSize="12" Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                            <materialDesign:PackIcon x:Name="IconNewLower" Kind="CircleOutline" Width="16" Height="16" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtNewLower" Text="En az 1 küçük harf" FontSize="12" Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                            <materialDesign:PackIcon x:Name="IconNewSymbol" Kind="CircleOutline" Width="16" Height="16" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtNewSymbol" Text="En az 1 sembol" FontSize="12" Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>


                            <!-- Row 4: Lisans Anahtarı -->
                            <StackPanel Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="KeyOutline" Width="18" Height="18" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Lisans Anahtarı" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="TxtNewLicenseKey" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Kaydedildiğinde otomatik oluşturulacaktır" Margin="0,0,0,0" 
                                         IsReadOnly="True" Foreground="#64748B" Height="48" Background="#F8FAFC"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="TxtUserError" Foreground="#D32F2F" FontSize="13" Margin="0,0,0,20" 
                                     HorizontalAlignment="Left" Visibility="Collapsed" TextWrapping="Wrap"/>
                            
                            <!-- Footer Buttons -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                        Click="BtnCancel_Click" Foreground="#7E84A3" BorderBrush="#CBD5E1" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Vazgeç" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Foreground="White" Background="#E02020" BorderBrush="#E02020" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="Bold"
                                        Click="BtnSaveUser_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Kaydet ve Kapat" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- Kullanıcı Düzenleme (Sadece Rol) Dialog Overlay -->
        <Grid x:Name="EditUserDialogOverlay" Grid.RowSpan="3" Visibility="Collapsed">
            <Border Background="#111A1A24">
                <Border.Effect>
                    <BlurEffect Radius="15"/>
                </Border.Effect>
            </Border>
            <Grid Background="#22FFFFFF">
                <materialDesign:Card Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="25" Background="White">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.2" Direction="270" ShadowDepth="10"/>
                    </materialDesign:Card.Effect>
                    <Border Padding="35">
                        <StackPanel>
                            <!-- Header Icon and Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24" HorizontalAlignment="Center">
                                <Border Width="50" Height="50" Background="#EEF2FF" CornerRadius="16" Margin="0,0,16,0">
                                    <materialDesign:PackIcon Kind="ShieldAccountOutline" Width="26" Height="26" Foreground="#3949AB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Yetki Düzenle" FontSize="20" FontWeight="Bold" Foreground="#1A1A24"/>
                                    <TextBlock x:Name="TxtEditUserSubtitle" Text="" FontSize="13" Foreground="#7E84A3" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#F1F5F9" Margin="0,0,0,20"/>

                            <StackPanel Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="ShieldAccountOutline" Width="18" Height="18" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Yetki Rolü" FontSize="13" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ComboBox x:Name="CmbEditRole" Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="48">
                                    <ComboBoxItem Content="User" IsSelected="True"/>
                                    <ComboBoxItem Content="Admin"/>
                                </ComboBox>
                            </StackPanel>

                            <TextBlock x:Name="TxtEditUserError" Foreground="#D32F2F" FontSize="13" Margin="0,0,0,15" 
                                     HorizontalAlignment="Left" Visibility="Collapsed" TextWrapping="Wrap"/>

                            <!-- Footer Buttons -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                        Click="BtnCancelEdit_Click" Foreground="#7E84A3" BorderBrush="#CBD5E1" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Vazgeç" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Foreground="White" Background="#3949AB" BorderBrush="#3949AB" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="Bold"
                                        Click="BtnSaveEditUser_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Kaydet" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- Notification Dialog Overlay -->
        <Grid x:Name="NotificationDialogOverlay" Grid.RowSpan="3" Visibility="Collapsed">
            <Border Background="#111A1A24">
                <Border.Effect>
                    <BlurEffect Radius="15"/>
                </Border.Effect>
            </Border>
            <Grid Background="#22FFFFFF">
                <materialDesign:Card Width="540" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    UniformCornerRadius="25" Background="White">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.15" Direction="270" ShadowDepth="10"/>
                    </materialDesign:Card.Effect>
                    <Border Padding="35">
                        <StackPanel>
                            <!-- Header Icon and Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24" HorizontalAlignment="Left">
                                <Border Width="50" Height="50" Background="#EEF2FF" CornerRadius="16" Margin="0,0,16,0">
                                    <materialDesign:PackIcon Kind="BellRingOutline" Width="26" Height="26" Foreground="#3949AB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Yeni Bildirim Gönder" FontSize="20" FontWeight="Bold" Foreground="#1A1A24"/>
                                    <TextBlock Text="Kullanıcılara anlık mesaj veya duyuru yayınlayın" FontSize="13" Foreground="#7E84A3" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#F1F5F9" Margin="0,0,0,20"/>

                            <!-- Row 1: Alıcı & Bildirim Tipi (2 Columns) -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Alıcı" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="CmbNotifyUser" Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="48">
                                        <ComboBoxItem Content="Tüm Kullanıcılar" IsSelected="True" Tag="All"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Bildirim Tipi" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                    <ComboBox x:Name="CmbNotifyType" Style="{StaticResource MaterialDesignOutlinedComboBox}" Height="48">
                                        <ComboBoxItem Content="Bilgi (Info)" Tag="Info" IsSelected="True"/>
                                        <ComboBoxItem Content="Başarı (Success)" Tag="Success"/>
                                        <ComboBoxItem Content="Uyarı (Warning)" Tag="Warning"/>
                                        <ComboBoxItem Content="Hata (Error)" Tag="Error"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Başlık -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Bildirim Başlığı" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                <TextBox x:Name="TxtNotifyTitle" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Kısa ve açıklayıcı bir başlık yazın..." Height="48"
                                         materialDesign:TextFieldAssist.HasClearButton="True"/>
                            </StackPanel>

                            <!-- Row 3: Mesaj İçeriği -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Mesaj İçeriği" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,8"/>
                                <TextBox x:Name="TxtNotifyMessage" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Kullanıcılara iletilecek mesaj detaylarını buraya yazın..."
                                         AcceptsReturn="True" Height="120" VerticalContentAlignment="Top" Padding="16,12" TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock x:Name="TxtNotifyError" Foreground="#D32F2F" FontSize="13" Margin="0,0,0,20" 
                                     HorizontalAlignment="Left" Visibility="Collapsed" TextWrapping="Wrap"/>

                            <!-- Footer Buttons -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Vazgeç" Style="{StaticResource MaterialDesignOutlinedButton}" 
                                        Click="BtnCancelNotify_Click" Foreground="#7E84A3" BorderBrush="#CBD5E1" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" Margin="0,0,12,0"/>
                                <Button Grid.Column="1" Content="Bildirimi Yayınla" Foreground="White" Background="#3949AB" BorderBrush="#3949AB" 
                                        materialDesign:ButtonAssist.CornerRadius="12" Height="48" FontWeight="Bold"
                                        Click="BtnSendNotification_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
