<Window x:Class="Synctool.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Synctool — Kayıt Ol" Width="1020" Height="640"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Icon="/Assets/synctoolAppIcon.png">

    <Window.Resources>
        <!-- Custom thin scrollbar style -->
        <Style x:Key="SleekScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle"
                                CornerRadius="3"
                                Background="#CBD5E1"
                                Height="Auto"
                                Width="6"
                                HorizontalAlignment="Center"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="rectangle" Property="Background" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SleekScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SleekScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SleekScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid x:Name="Grid" Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    CanHorizontallyScroll="False"
                                                    CanVerticallyScroll="False"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    Content="{TemplateBinding Content}"
                                                    Grid.Column="0"
                                                    Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource SleekScrollBar}"
                                       AutomationProperties.AutomationId="VerticalScrollBar"
                                       Cursor="Arrow"
                                       Grid.Column="1"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Minimum="0"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="20"  Background="White">
        <Border.Effect>
            <DropShadowEffect Color="#888888" BlurRadius="30" Opacity="0.25" Direction="270" ShadowDepth="6"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sol banner: sabit genişlik -->
                <ColumnDefinition Width="300"/>
                <!-- Sağ form paneli: kalan alan -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════════
                 SOL BANNER
            ═══════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#E02020" Offset="0"/>
                        <GradientStop Color="#B01010" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32">
                        <!-- Logo -->
                        <Viewbox Width="180" Margin="0,0,0,28">
                            <Image Source="/Assets/synctool.png" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Viewbox>

                        <!-- Başlık -->
                        <TextBlock Text="Hesap Oluştur"
                                   FontSize="20" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

                        <!-- Ayraç çizgi -->
                        <Border Height="1" Background="#FFCDCD" Opacity="0.4" Margin="0,0,0,16"/>

                        <!-- Özellikler listesi -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#FFCDCD" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Anlık maliyet hesaplama" FontSize="13" Foreground="#FFCDCD" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#FFCDCD" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Excel &amp; kampanya yönetimi" FontSize="13" Foreground="#FFCDCD" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="#FFCDCD" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Güvenli lisans sistemi" FontSize="13" Foreground="#FFCDCD" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer -->
                    <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center"
                               Margin="0,0,0,24" Foreground="#FFCDCD" FontSize="10"
                               Text="© 2026 Synctool Maliyet Yönetim Sistemi"/>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════
                 SAĞ FORM PANELİ
            ═══════════════════════════════════════════════════════ -->
            <Grid Grid.Column="1" Margin="30">

                <!-- Form içeriği -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="52,32,52,32">
                    <StackPanel>

                        <!-- Başlık & Alt başlık -->
                        <TextBlock Text="Yeni Hesap Oluştur"
                                   FontSize="26" FontWeight="Bold" Foreground="#1A1A24"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Tüm alanları eksiksiz doldurun, birkaç saniyede üye olun."
                                   FontSize="13" Foreground="#94A3B8" Margin="0,0,0,28"/>

                        <!-- ── Satır 1: Kullanıcı Adı & Bayi Adı ── -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Kullanıcı Adı -->
                            <Grid Grid.Column="0">
                                <TextBox x:Name="TxtRegUsername"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Kullanıcı Adı"
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Height="50" Padding="44,0,12,0" VerticalContentAlignment="Center"
                                         FontSize="14"/>
                                <materialDesign:PackIcon Kind="AccountOutline" Width="20" Height="20"
                                         Foreground="#94A3B8" VerticalAlignment="Center"
                                         HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Bayi Adı -->
                            <Grid Grid.Column="2">
                                <TextBox x:Name="TxtRegDealerName"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Bayi Adı"
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Height="50" Padding="44,0,12,0" VerticalContentAlignment="Center"
                                         FontSize="14"/>
                                <materialDesign:PackIcon Kind="StorefrontOutline" Width="20" Height="20"
                                         Foreground="#94A3B8" VerticalAlignment="Center"
                                         HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                        </Grid>

                        <!-- ── Satır 2: E-Posta (tam genişlik) ── -->
                        <Grid Margin="0,0,0,16">
                            <TextBox x:Name="TxtRegEmail"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="E-Posta Adresi"
                                     materialDesign:TextFieldAssist.HasClearButton="True"
                                     Height="50" Padding="44,0,12,0" VerticalContentAlignment="Center"
                                     FontSize="14"/>
                            <materialDesign:PackIcon Kind="EmailOutline" Width="20" Height="20"
                                     Foreground="#94A3B8" VerticalAlignment="Center"
                                     HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                        </Grid>

                        <!-- ── Satır 3: Şifre & Şifre Tekrar ── -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Şifre -->
                            <Grid Grid.Column="0" Height="50">
                                <PasswordBox x:Name="TxtRegPassword"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             materialDesign:HintAssist.Hint="Şifre"
                                             Padding="44,0,44,0" VerticalContentAlignment="Center" Height="50"
                                             FontSize="14"
                                             PasswordChanged="TxtRegPassword_PasswordChanged"/>
                                <TextBox x:Name="TxtRegPasswordVisible"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Şifre"
                                         Visibility="Collapsed" Padding="44,0,44,0"
                                         VerticalContentAlignment="Center" Height="50" FontSize="14"
                                         TextChanged="TxtRegPasswordVisible_TextChanged"/>
                                <materialDesign:PackIcon Kind="LockOutline" Width="20" Height="20"
                                         Foreground="#94A3B8" VerticalAlignment="Center"
                                         HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                                <Button x:Name="BtnRegShowPassword"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,6,0" Width="32" Height="32" Click="BtnRegShowPassword_Click">
                                    <materialDesign:PackIcon x:Name="IconRegShowPassword"
                                             Kind="EyeOffOutline" Width="18" Height="18" Foreground="#94A3B8"/>
                                </Button>
                            </Grid>

                            <!-- Şifre Tekrar -->
                            <Grid Grid.Column="2" Height="50">
                                <PasswordBox x:Name="TxtRegPasswordConfirm"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             materialDesign:HintAssist.Hint="Şifre (Tekrar)"
                                             Padding="44,0,44,0" VerticalContentAlignment="Center" Height="50"
                                             FontSize="14"/>
                                <TextBox x:Name="TxtRegPasswordConfirmVisible"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Şifre (Tekrar)"
                                         Visibility="Collapsed" Padding="44,0,44,0"
                                         VerticalContentAlignment="Center" Height="50" FontSize="14"/>
                                <materialDesign:PackIcon Kind="LockCheckOutline" Width="20" Height="20"
                                         Foreground="#94A3B8" VerticalAlignment="Center"
                                         HorizontalAlignment="Left" Margin="14,0,0,0" IsHitTestVisible="False"/>
                                <Button x:Name="BtnRegShowPasswordConfirm"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Focusable="False" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,6,0" Width="32" Height="32" Click="BtnRegShowPasswordConfirm_Click">
                                    <materialDesign:PackIcon x:Name="IconRegShowPasswordConfirm"
                                             Kind="EyeOffOutline" Width="18" Height="18" Foreground="#94A3B8"/>
                                </Button>
                            </Grid>
                        </Grid>

                        <!-- ── Şifre Güvenlik Göstergesi ── -->
                        <Border Background="#F8FAFC" CornerRadius="12"
                                BorderThickness="1" BorderBrush="#E2E8F0"
                                Padding="18,14" Margin="0,0,0,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.ColumnSpan="2" Grid.Row="0"
                                           Text="Şifre Güvenlik Gereksinimleri"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#64748B" Margin="0,0,0,10"/>

                                <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                                    <materialDesign:PackIcon x:Name="IconRegLength" Kind="CircleOutline"
                                             Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtRegLength" Text="En az 8 karakter"
                                               FontSize="12" Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                                    <materialDesign:PackIcon x:Name="IconRegUpper" Kind="CircleOutline"
                                             Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtRegUpper" Text="En az 1 büyük harf"
                                               FontSize="12" Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal">
                                    <materialDesign:PackIcon x:Name="IconRegLower" Kind="CircleOutline"
                                             Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtRegLower" Text="En az 1 küçük harf"
                                               FontSize="12" Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal">
                                    <materialDesign:PackIcon x:Name="IconRegSymbol" Kind="CircleOutline"
                                             Width="14" Height="14" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtRegSymbol" Text="En az 1 özel karakter"
                                               FontSize="12" Foreground="#64748B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Sözleşme Checkbox ── -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <CheckBox x:Name="ChkAgreement" VerticalAlignment="Center" PreviewMouseLeftButtonDown="ChkAgreement_PreviewMouseLeftButtonDown"/>
                            <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" FontSize="13">
                                <Hyperlink Click="LnkAgreement_Click" Foreground="#E02020"
                                           TextDecorations="{x:Null}" FontWeight="SemiBold">Kullanıcı Sözleşmesini</Hyperlink>
                                <Run Text=" okudum ve kabul ediyorum." Foreground="#64748B"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- ── Kayıt Ol Butonu ── -->
                        <Button x:Name="BtnRegister"
                                Content="Hesap Oluştur"
                                Foreground="White" Height="50"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                Background="#E02020" BorderBrush="#E02020"
                                FontSize="15" FontWeight="Bold"
                                Click="BtnRegister_Click" Margin="0,0,0,14"/>

                        <!-- ── Giriş Yap Linki ── -->
                        <TextBlock HorizontalAlignment="Center" FontSize="13">
                            <Run Text="Zaten hesabınız var mı?" Foreground="#94A3B8"/>
                            <Hyperlink Click="BtnSwitchToLogin_Click" Foreground="#E02020"
                                       FontWeight="Bold" TextDecorations="{x:Null}"> Giriş Yap</Hyperlink>
                        </TextBlock>

                        <!-- ── Hata Mesajı ── -->
                        <Border x:Name="ErrorBorder" Visibility="Collapsed"
                                Background="#FFF5F5" CornerRadius="10"
                                BorderBrush="#FCA5A5" BorderThickness="1"
                                Padding="14,10" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                         Foreground="#EF4444" Width="18" Height="18"
                                         VerticalAlignment="Top" Margin="0,1,0,0"/>
                                <TextBlock x:Name="TxtRegError" Foreground="#B91C1C"
                                           FontSize="13" TextWrapping="Wrap"
                                           Margin="10,0,0,0" LineHeight="18"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Kapat Butonu -->
                <Button Style="{StaticResource MaterialDesignFloatingActionMiniLightButton}"
                        Background="Transparent" BorderBrush="Transparent"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-10,-10,0" Click="BtnClose_Click" ToolTip="Kapat">
                    <materialDesign:PackIcon Kind="Close" Foreground="#64748B" Width="20" Height="20"/>
                </Button>
            </Grid>

            <!-- ══════════════════════════════════════════════════════
                 TOAST BİLDİRİMİ
            ═══════════════════════════════════════════════════════ -->
            <materialDesign:Card x:Name="ToastCard" Grid.ColumnSpan="2"
                                Visibility="Collapsed" Opacity="0"
                                VerticalAlignment="Top" HorizontalAlignment="Right"
                                Margin="0,26,26,0" UniformCornerRadius="12"
                                Background="White" Width="340"
                                materialDesign:ElevationAssist.Elevation="Dp6">
                <materialDesign:Card.RenderTransform>
                    <TranslateTransform X="50"/>
                </materialDesign:Card.RenderTransform>
                <Border BorderBrush="#10B981" BorderThickness="4,0,0,0" Padding="20,14">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle"
                                 Foreground="#10B981" Width="24" Height="24" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtToastMessage"
                                   Foreground="#1A1A24" FontWeight="SemiBold" FontSize="14"
                                   Margin="14,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </materialDesign:Card>

            <!-- ══════════════════════════════════════════════════════
                 SÖZLEŞME OVERLAY
            ═══════════════════════════════════════════════════════ -->
            <Grid x:Name="AgreementOverlay" Grid.ColumnSpan="2"
                  Background="#BB1A1A24" Visibility="Collapsed">
                <materialDesign:Card Width="520" Height="460"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    UniformCornerRadius="20" Padding="0">
                    <materialDesign:Card.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.3" Direction="270" ShadowDepth="12"/>
                    </materialDesign:Card.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" CornerRadius="20,20,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A1A24" Offset="0"/>
                                    <GradientStop Color="#2D2D3A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal" Margin="24,16">
                                <materialDesign:PackIcon Kind="FileDocumentOutline"
                                         Foreground="White" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtAgreementVersion"
                                           Text="Kullanıcı Sözleşmesi"
                                           Foreground="White" FontSize="17" FontWeight="Bold"
                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- İçerik -->
                        <ScrollViewer x:Name="AgreementScrollViewer" Grid.Row="1" Margin="24,10"
                                      Style="{StaticResource SleekScrollViewer}"
                                      ScrollChanged="AgreementScrollViewer_ScrollChanged">
                            <TextBlock x:Name="TxtAgreementContent"
                                       TextWrapping="Wrap" Foreground="#374151"
                                       FontSize="13" LineHeight="20"/>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,20,20" Padding="24,16">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Reddet"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="#64748B" BorderBrush="#CBD5E1"
                                        Margin="0,0,12,0" Height="38"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Click="BtnCloseAgreement_Click"/>
                                <Button x:Name="BtnAcceptAgreement"
                                        Content="Kabul Ediyorum"
                                        Background="#10B981" BorderBrush="#10B981"
                                        Foreground="White" Height="38"
                                        FontWeight="SemiBold"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Click="BtnAcceptAgreement_Click"
                                        IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>

        </Grid>
    </Border>
</Window>
