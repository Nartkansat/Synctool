<UserControl x:Class="ArcelikExcelApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F5F7FA"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <!-- İnce ScrollBar Stili -->
        <Style TargetType="ScrollBar" BasedOn="{StaticResource MaterialDesignScrollBarMinimal}" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource MaterialDesignScrollViewer}">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Başlık Alanı -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Genel İstatistikler &amp; Dashboard" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Sistemdeki ürünlerin, fiyatların ve analizlerin güncel özeti" FontSize="15" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>
                
                <!-- Güvenlik / Sistem Durum Rozeti -->
                <Border Grid.Column="1" VerticalAlignment="Center" Background="#ECFDF5" CornerRadius="20" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ShieldCheck" Width="24" Height="24" Foreground="#10B981" VerticalAlignment="Center"/>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtSystemStatus" Text="Sistem Güvende • Aktif" FontSize="14" FontWeight="Bold" Foreground="#065F46"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Son Veri:" FontSize="12" Foreground="#64748B"/>
                                <TextBlock x:Name="TxtLastUpdate" Text="---" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Üst İstatistik Kartları (Sayısal Veriler) -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="-12,0,-12,24">
                <!-- Toplam Ürün -->
                <materialDesign:Card Margin="12" UniformCornerRadius="20" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="64" Height="64" CornerRadius="32" Background="#EEF2FF">
                            <materialDesign:PackIcon Kind="PackageVariant" Width="32" Height="32" Foreground="#4F46E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Toplam Ürün" FontSize="15" FontWeight="SemiBold" Foreground="#64748B"/>
                            <TextBlock x:Name="TxtTotalProducts" Text="0" FontSize="28" FontWeight="ExtraBold" Foreground="#1E293B" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Kampanyalar -->
                <materialDesign:Card Margin="12" UniformCornerRadius="20" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="64" Height="64" CornerRadius="32" Background="#FFF1F2">
                            <materialDesign:PackIcon Kind="TicketPercent" Width="32" Height="32" Foreground="#E11D48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Aktif Kampanyalar" FontSize="15" FontWeight="SemiBold" Foreground="#64748B"/>
                            <TextBlock x:Name="TxtTotalCampaigns" Text="0" FontSize="28" FontWeight="ExtraBold" Foreground="#1E293B" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Yüklenen Dosyalar -->
                <materialDesign:Card Margin="12" UniformCornerRadius="20" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="64" Height="64" CornerRadius="32" Background="#F0FDF4">
                            <materialDesign:PackIcon Kind="FileExcel" Width="32" Height="32" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Excel Yüklemeleri" FontSize="15" FontWeight="SemiBold" Foreground="#64748B"/>
                            <TextBlock x:Name="TxtTotalFiles" Text="0" FontSize="28" FontWeight="ExtraBold" Foreground="#1E293B" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Kampanya Etki Oranı -->
                <materialDesign:Card Margin="12" UniformCornerRadius="20" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="24">
                        <StackPanel>
                            <TextBlock Text="Maliyetlerde Kampanya Etkisi" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar x:Name="ProgCampaign" Value="0" Height="12" Foreground="#3B82F6" Background="#E2E8F0" materialDesign:TransitionAssist.DisableTransitions="True" VerticalAlignment="Center" Margin="0,0,16,0" Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                                <TextBlock Grid.Column="1" x:Name="TxtCampaignRatio" Text="%0" FontSize="24" FontWeight="ExtraBold" Foreground="#1E293B"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Orta Bölüm (Finansal Veriler & Veri Dağılımı) -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Sol Kısım: Finansal Ortalamalar Kartı (Premium Gradient) -->
                <Border Grid.Column="0" CornerRadius="24" Margin="0,0,16,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#DC2626" Offset="0.0" />
                            <GradientStop Color="#991B1B" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <!-- Shadow -->
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="10" Color="#991B1B" />
                    </Border.Effect>
                    <Grid Margin="32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,32">
                            <Border Background="#B91C1C" CornerRadius="12" Padding="8">
                                <materialDesign:PackIcon Kind="Finance" Width="28" Height="28" Foreground="White" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Ortalama Fiyat Analizleri (30 Günlük Toptan)" FontSize="22" FontWeight="Bold" Foreground="White" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="KEA Ortalama Fiyat" FontSize="16" FontWeight="Medium" Foreground="#FECACA"/>
                                <TextBlock x:Name="TxtKeaAvgPrice" Text="0 ₺" FontSize="40" FontWeight="ExtraBold" Foreground="White" Margin="0,8,0,0"/>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Width="1" Fill="#FCA5A5" Margin="40,0" RadiusX="1" RadiusY="1" Opacity="0.5"/>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Beyaz Eşya Ortalama Fiyat" FontSize="16" FontWeight="Medium" Foreground="#FECACA"/>
                                <TextBlock x:Name="TxtWgAvgPrice" Text="0 ₺" FontSize="40" FontWeight="ExtraBold" Foreground="White" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Sağ Kısım: Veritabanı Dağılımı -->
                <materialDesign:Card Grid.Column="1" UniformCornerRadius="24" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="28">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <materialDesign:PackIcon Kind="ChartDonut" Width="24" Height="24" Foreground="#1E293B"/>
                                <TextBlock Text="Kategori Dağılımı" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- KEA -->
                            <StackPanel Margin="0,0,0,24">
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Küçük Ev Aletleri" FontSize="15" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="TxtKeaRatio" Text="%0" FontSize="15" FontWeight="Bold" Foreground="#E11D48" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar x:Name="ProgKea" Value="0" Height="10" Foreground="#E11D48" Background="#FFE4E6" materialDesign:TransitionAssist.DisableTransitions="True"/>
                            </StackPanel>

                            <!-- Beyaz Eşya -->
                            <StackPanel Margin="0,0,0,20">
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Beyaz Eşya" FontSize="15" FontWeight="SemiBold" Foreground="#475569" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="TxtWgRatio" Text="%0" FontSize="15" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Right"/>
                                </Grid>
                                <ProgressBar x:Name="ProgWg" Value="0" Height="10" Foreground="#3B82F6" Background="#EFF6FF" materialDesign:TransitionAssist.DisableTransitions="True"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- Alt Bölüm: Bildirimler -->
            <Grid Grid.Row="3">
                <!-- Son Bildirimler -->
                <materialDesign:Card UniformCornerRadius="24" Background="White" materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,24">
                            <materialDesign:PackIcon Kind="BellRing" Width="24" Height="24" Foreground="#1E293B"/>
                            <TextBlock Text="Son Bildirimler" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Empty State -->
                        <StackPanel x:Name="EmptyNotificationsPanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,40,0,0">
                            <materialDesign:PackIcon Kind="BellOffOutline" Width="48" Height="48" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            <TextBlock Text="Henüz yeni bir bildirim yok." FontSize="14" Foreground="#94A3B8" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Notification List -->
                        <ItemsControl x:Name="ListRecentNotifications" Grid.Row="1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="40" Height="40" CornerRadius="20" Background="#EEF2FF" VerticalAlignment="Top">
                                                <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20" Foreground="#4F46E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Message}" FontSize="13" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,0" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" FontSize="11" FontWeight="Medium" Foreground="#94A3B8" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
