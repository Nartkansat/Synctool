<UserControl x:Class="Synctool.Views.KampanyaDegisimView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:Synctool.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="Transparent">

    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Dosya Seçim Alanları -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 1. Excel (Eski/Referans) -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,10,20" UniformCornerRadius="16" materialDesign:ElevationAssist.Elevation="Dp2">
                <Border Padding="20">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Border Width="36" Height="36" CornerRadius="10" Background="#F1F5F9" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="FileOutline" Width="20" Height="20" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="1. Excel Dosyası (Referans)" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="Karşılaştırma yapılacak eski fiyat listesi" FontSize="11" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="12" 
                            Background="#F8FAFC" Padding="15" Margin="0,0,0,15"
                            AllowDrop="True" Drop="Border1_Drop" Cursor="Hand" MouseLeftButtonDown="Border1_MouseLeftButtonDown">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="CloudUploadOutline" Width="32" Height="32" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtFile1" Text="Dosya Seçmek İçin Tıklayın" FontSize="12" Foreground="#64748B" Margin="0,8,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" x:Name="Options1" Visibility="Collapsed">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <ComboBox x:Name="CmbSheet1" Grid.Column="0" Margin="0,0,8,0"
                                      materialDesign:HintAssist.Hint="Sayfa Seçin"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      SelectionChanged="CmbSheet1_SelectionChanged"/>
                            
                            <ComboBox x:Name="CmbCode1" Grid.Column="1" Margin="0,0,8,0"
                                      materialDesign:HintAssist.Hint="Ürün Kodu Kolonu"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                            
                            <ComboBox x:Name="CmbName1" Grid.Column="2" Margin="0,0,8,0"
                                      materialDesign:HintAssist.Hint="Ürün Adı Kolonu"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                            
                            <ComboBox x:Name="CmbPrice1" Grid.Column="3"
                                      materialDesign:HintAssist.Hint="Fiyat Kolonu"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </Grid>
                    </StackPanel>
                    </Grid>
                </Border>
            </materialDesign:Card>

            <!-- 2. Excel (Yeni/Güncel) -->
            <materialDesign:Card Grid.Column="1" Margin="10,0,10,20" UniformCornerRadius="16" materialDesign:ElevationAssist.Elevation="Dp2">
                <Border Padding="20">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Border Width="36" Height="36" CornerRadius="10" Background="#F0FDF4" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="FileCheckOutline" Width="20" Height="20" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="2. Excel Dosyası (Güncel)" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="Daha yeni olan, güncel fiyat listesi" FontSize="11" Foreground="#94A3B8"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="#DCFCE7" BorderThickness="2" CornerRadius="12" 
                            Background="#F0FDF4" Padding="15" Margin="0,0,0,15"
                            AllowDrop="True" Drop="Border2_Drop" Cursor="Hand" MouseLeftButtonDown="Border2_MouseLeftButtonDown">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="CloudUploadOutline" Width="32" Height="32" Foreground="#BBF7D0" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtFile2" Text="Dosya Seçmek İçin Tıklayın" FontSize="12" Foreground="#16A34A" Margin="0,8,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" x:Name="Options2" Visibility="Collapsed">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <ComboBox x:Name="CmbSheet2" Grid.Column="0" Margin="0,0,8,0"
                                      materialDesign:HintAssist.Hint="Sayfa Seçin"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      SelectionChanged="CmbSheet2_SelectionChanged"/>
                            
                            <ComboBox x:Name="CmbCode2" Grid.Column="1" Margin="0,0,8,0"
                                      materialDesign:HintAssist.Hint="Ürün Kodu Kolonu"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                            
                            <ComboBox x:Name="CmbName2" Grid.Column="2" Margin="0,0,8,0"
                                      materialDesign:HintAssist.Hint="Ürün Adı Kolonu"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                            
                            <ComboBox x:Name="CmbPrice2" Grid.Column="3"
                                      materialDesign:HintAssist.Hint="Fiyat Kolonu"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </Grid>
                    </StackPanel>
                    </Grid>
                </Border>
            </materialDesign:Card>

            <!-- 3. Analiz Kontrolü -->
            <materialDesign:Card Grid.Column="2" Margin="10,0,0,20" Width="400" UniformCornerRadius="16" materialDesign:ElevationAssist.Elevation="Dp2">
                <Border Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Width="36" Height="36" CornerRadius="10" Background="#F5F3FF" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="LightningBoltOutline" Width="20" Height="20" Foreground="#7C3AED" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="3. Karşılaştırma" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Fiyat değişim analizini başlat" FontSize="11" Foreground="#94A3B8"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#E9D5FF" BorderThickness="2" CornerRadius="12" 
                                Background="#FAF5FF" Padding="0">
                            <Grid VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <materialDesign:PackIcon Grid.Row="0" Kind="SwapHorizontalCircle" Width="36" Height="36" Foreground="#C084FC" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <Button Grid.Row="1" x:Name="BtnAnalyze" 
                                        Content="ANALİZİ BAŞLAT"
                                        FontSize="14"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#7C3AED" BorderBrush="#7C3AED" Foreground="White"
                                        Height="28" Width="190"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Click="BtnAnalyze_Click"
                                        IsEnabled="False">
                                    <Button.Effect>
                                        <DropShadowEffect Color="#7C3AED" BlurRadius="12" Opacity="0.3" ShadowDepth="3"/>
                                    </Button.Effect>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </materialDesign:Card>
        </Grid>

        <!-- Sonuçlar -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="20" materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="25,15" Background="#F8FAFC" CornerRadius="20,20,0,0" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="TableSearch" Width="20" Height="20" Foreground="#6366F1" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Karşılaştırma Sonuçları" FontSize="15" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                             <Button x:Name="BtnExport" Content="Excel'e Aktar" 
                                    Style="{StaticResource MaterialDesignFlatButton}" 
                                    Foreground="#16A34A" FontWeight="Bold"
                                    Visibility="Collapsed"
                                    Click="BtnExport_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid x:Name="GridResults" Grid.Row="1" 
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="White" BorderThickness="0" 
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          Padding="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ürün Kodu" Binding="{Binding ProductCode}" Width="150" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Ürün Adı" Binding="{Binding ProductName}" Width="*" Foreground="#64748B"/>
                        <DataGridTextColumn Header="Eski Fiyat" Binding="{Binding OldPrice, StringFormat={}{0:N2} ₺}" Width="130"/>
                        <DataGridTextColumn Header="Yeni Fiyat" Binding="{Binding NewPrice, StringFormat={}{0:N2} ₺}" Width="150"/>
                        
                        <DataGridTemplateColumn Header="Fark" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Difference, StringFormat={}{0:N2} ₺}" 
                                               FontWeight="Bold"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#1E293B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Artış">
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Azalış">
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Değişim (%)" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="6,2" CornerRadius="6" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Artış">
                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Azalış">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding DifferencePercentage, StringFormat={}{0:P1}}" 
                                                   FontSize="12" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Artış">
                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Azalış">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Durum" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="Minus"/>
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Artış">
                                                            <Setter Property="Kind" Value="TrendingUp"/>
                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Azalış">
                                                            <Setter Property="Kind" Value="TrendingDown"/>
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                        <TextBlock Text="{Binding Status}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Artış">
                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Azalış">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading Overlay -->
                <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Background="#CCFFFFFF" Grid.RowSpan="2">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" 
                                     Width="48" Height="48" Foreground="#7C3AED" Margin="0,0,0,15"/>
                        <TextBlock Text="Karşılaştırılıyor..." FontSize="16" FontWeight="SemiBold" Foreground="#475569"/>
                    </StackPanel>
                </Grid>
                
                <!-- Boş State -->
                <Grid x:Name="EmptyState" Grid.Row="1" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ChartBoxOutline" Width="64" Height="64" Foreground="#F1F5F9" HorizontalAlignment="Center"/>
                        <TextBlock Text="Henüz karşılaştırma yapılmadı" FontSize="14" Foreground="#94A3B8" Margin="0,15,0,0"/>
                        <TextBlock Text="Dosyaları seçin ve başlat butonuna tıklayın" FontSize="12" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- Snackbar -->
        <materialDesign:Snackbar x:Name="ViewSnackbar" Grid.Row="1" MessageQueue="{materialDesign:MessageQueue}" />
    </Grid>
</UserControl>
