<UserControl x:Class="Synctool.Views.StokMaliyetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F4F6F8"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Excel Upload & Options -->
            <RowDefinition Height="Auto"/> <!-- Summary Statistics Cards -->
            <RowDefinition Height="*"/>    <!-- Preview Grid -->
        </Grid.RowDefinitions>

        <!-- Excel Upload & Options Panel -->
        <Border Grid.Row="0" Background="White" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/> <!-- Drag & Drop File Picker -->
                    <ColumnDefinition Width="*"/>   <!-- Mapping and Calculation Parameters -->
                </Grid.ColumnDefinitions>

                <!-- Drag & Drop Border -->
                <Border Grid.Column="0" BorderBrush="#D1D5DB" BorderThickness="2" CornerRadius="8"
                        Background="#F9FAFB" Padding="12" AllowDrop="True" Height="140"
                        Drop="Border_Drop" Cursor="Hand" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="CloudUpload" Width="40" Height="40" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Dosya Seçmek İçin Tıklayın veya Sürükleyin" Foreground="#6B7280" FontSize="11" Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtSelectedFile" Text="" Foreground="#E02020" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,5,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Configuration & Action Parameters -->
                <WrapPanel Grid.Column="1" Margin="20,0,0,0" Orientation="Horizontal">
                    
                    <!-- Ürün Kodu Kolon Seçimi -->
                    <StackPanel Margin="0,0,16,8" VerticalAlignment="Bottom">
                        <TextBlock Text="Ürün Kodu Kolonu" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbCodeColumn" Width="160"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Kolon Seçin"
                                  IsEnabled="False"/>
                    </StackPanel>

                    <!-- Stok Adedi Kolon Seçimi -->
                    <StackPanel Margin="0,0,16,8" VerticalAlignment="Bottom">
                        <TextBlock Text="Stok Adedi Kolonu" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbStockColumn" Width="160"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Kolon Seçin"
                                  IsEnabled="False"/>
                    </StackPanel>

                    <!-- Valör Filtresi -->
                    <StackPanel Margin="0,0,16,8" VerticalAlignment="Bottom">
                        <TextBlock Text="Hesaplama Valörü" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbValor" Width="160"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Valör Seçin">
                            <ComboBoxItem Content="Ayarlanan Valörler" Tag="Personal" IsSelected="True"/>
                            <ComboBoxItem Content="60 Günlük (Varsayılan)" Tag="WholesalePrice60"/>
                            <ComboBoxItem Content="Peşin Fiyat" Tag="CashPrice"/>
                            <ComboBoxItem Content="30 Günlük" Tag="WholesalePrice30"/>
                            <ComboBoxItem Content="90 Günlük" Tag="WholesalePrice90"/>
                            <ComboBoxItem Content="120 Günlük" Tag="WholesalePrice120"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Fiyat Tipi Filtresi -->
                    <StackPanel Margin="0,0,16,8" VerticalAlignment="Bottom">
                        <TextBlock Text="Fiyat Tipi" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbPriceType" Width="160"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Tipi Seçin">
                            <ComboBoxItem Content="İndirimli (Maliyet)" IsSelected="True" Tag="Discounted"/>
                            <ComboBoxItem Content="İndirimsiz (Liste Fiyatı)" Tag="Undiscounted"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Hesapla ve Dışa Aktar Butonları -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,8">
                        <!-- Hesapla -->
                        <Button x:Name="BtnCalculate"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#E02020" BorderBrush="Transparent" Foreground="White"
                                Height="40" Padding="16,0" Margin="0,0,10,0" IsEnabled="False"
                                Click="BtnCalculate_Click">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PlayCircle" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Hesapla" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>

                        <!-- Dışa Aktar -->
                        <Button x:Name="BtnExport"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#1D6F42" BorderBrush="#1D6F42"
                                Height="40" Padding="16,0" IsEnabled="False"
                                Click="BtnExport_Click">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Excel'e Aktar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </StackPanel>

                </WrapPanel>
            </Grid>
        </Border>

        <!-- Summary Statistics Cards -->
        <Grid Grid.Row="1" Margin="16,16,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Toplam Satır Card -->
            <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="16" UniformCornerRadius="10" Background="White">
                <StackPanel>
                    <TextBlock Text="Toplam Excel Satırı" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <Grid Margin="0,8,0,0">
                        <TextBlock x:Name="TxtTotalRows" Text="0" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                        <materialDesign:PackIcon Kind="FormatListNumbered" Width="24" Height="24" Foreground="#3B82F6" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Eşleşen Ürünler Card -->
            <materialDesign:Card Grid.Column="1" Margin="8,0,8,0" Padding="16" UniformCornerRadius="10" Background="White">
                <StackPanel>
                    <TextBlock Text="Eşleşen Ürün Sayısı" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <Grid Margin="0,8,0,0">
                        <TextBlock x:Name="TxtMatchedRows" Text="0" FontSize="24" FontWeight="Bold" Foreground="#16A34A"/>
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="24" Height="24" Foreground="#16A34A" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Eşleşmeyen Ürünler Card -->
            <materialDesign:Card Grid.Column="2" Margin="8,0,8,0" Padding="16" UniformCornerRadius="10" Background="White">
                <StackPanel>
                    <TextBlock Text="Eşleşmeyen Ürün Sayısı" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <Grid Margin="0,8,0,0">
                        <TextBlock x:Name="TxtUnmatchedRows" Text="0" FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Width="24" Height="24" Foreground="#DC2626" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Toplam Değerleme Card -->
            <materialDesign:Card Grid.Column="3" Margin="8,0,0,0" Padding="16" UniformCornerRadius="10" Background="White">
                <StackPanel>
                    <TextBlock Text="Toplam Stok Maliyet Tutarı" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                    <Grid Margin="0,8,0,0">
                        <TextBlock x:Name="TxtTotalValue" Text="0.00 ₺" FontSize="20" FontWeight="Bold" Foreground="#E02020"/>
                        <materialDesign:PackIcon Kind="CurrencyTry" Width="24" Height="24" Foreground="#E02020" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <!-- Preview Grid Card -->
        <materialDesign:Card Grid.Row="2" Margin="16,16,16,16" UniformCornerRadius="10" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Search & Filter Panel -->
                    <RowDefinition Height="*"/>    <!-- Data Grid -->
                </Grid.RowDefinitions>

                <!-- Search Panel -->
                <Border Grid.Row="0" Background="#F8FAFC" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtSearch" Width="260"
                                     materialDesign:HintAssist.Hint="Arama (Kod veya Ürün Adı)..."
                                     materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                     BorderThickness="0" Background="Transparent" VerticalAlignment="Center"
                                     TextChanged="TxtSearch_TextChanged"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtGridSummary" Text="Sonuçları görmek için Excel yükleyip hesaplayın." HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="#64748B"/>
                    </Grid>
                </Border>

                <!-- Preview Grid -->
                <DataGrid Grid.Row="1" x:Name="GridPreview" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="White" BorderThickness="0" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ürün Kodu (Excel)" Binding="{Binding ExcelProductCode}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Stok Adedi (Excel)" Binding="{Binding ExcelStockCount}" Width="130"/>

                        <!-- Match Status Badge -->
                        <DataGridTemplateColumn Header="Durum" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="8,4" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FEF2F2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind" Value="CloseCircleOutline"/>
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                                <Setter Property="Kind" Value="CheckCircleOutline"/>
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                            <TextBlock FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Eşleşmedi"/>
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                                                <Setter Property="Text" Value="Eşleşti"/>
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Ürün Adı (DB)" Binding="{Binding DbProductName}" Width="*"/>

                        <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding UnitPrice, StringFormat={}{0:N2} ₺}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Toplam Tutar" Binding="{Binding TotalCost, StringFormat={}{0:N2} ₺}" Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#E02020"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Background="#B2FFFFFF" Grid.RowSpan="3" Panel.ZIndex="99">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True"
                             Width="56" Height="56" Foreground="#E02020" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtLoadingMessage" Text="Veritabanı Kataloğu Yükleniyor..." Margin="0,15,0,0" FontWeight="SemiBold"
                           Foreground="#374151" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
