<UserControl x:Class="ArcelikExcelApp.Views.TarihceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F4F6F8"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filters -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,15">
            <WrapPanel Orientation="Horizontal">
                <!-- Ürün Grubu -->
                <StackPanel Margin="0,0,20,10">
                    <TextBlock Text="Ürün Grubu" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbProductGroup" Width="150" SelectionChanged="ProductGroup_SelectionChanged"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}">
                        <ComboBoxItem Content="Beyaz Eşya" IsSelected="True" Tag="BeyazEsya"/>
                        <ComboBoxItem Content="Küçük Ev Aletleri (KEA)" Tag="Kea"/>
                    </ComboBox>
                </StackPanel>

                <!-- Yıl Seçimi -->
                <StackPanel Margin="0,0,20,10">
                    <TextBlock Text="Yıl" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbYear" Width="100" SelectionChanged="Filter_Changed"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </StackPanel>

                <!-- Ay Seçimi -->
                <StackPanel Margin="0,0,20,10">
                    <TextBlock Text="Ay" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbMonth" Width="120" SelectionChanged="Filter_Changed"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}">
                        <ComboBoxItem Content="Ocak" Tag="1"/>
                        <ComboBoxItem Content="Şubat" Tag="2"/>
                        <ComboBoxItem Content="Mart" Tag="3"/>
                        <ComboBoxItem Content="Nisan" Tag="4"/>
                        <ComboBoxItem Content="Mayıs" Tag="5"/>
                        <ComboBoxItem Content="Haziran" Tag="6"/>
                        <ComboBoxItem Content="Temmuz" Tag="7"/>
                        <ComboBoxItem Content="Ağustos" Tag="8"/>
                        <ComboBoxItem Content="Eylül" Tag="9"/>
                        <ComboBoxItem Content="Ekim" Tag="10"/>
                        <ComboBoxItem Content="Kasım" Tag="11"/>
                        <ComboBoxItem Content="Aralık" Tag="12"/>
                    </ComboBox>
                </StackPanel>

                <!-- Kategori Seçimi -->
                <StackPanel Margin="0,0,20,10">
                    <TextBlock Text="Kategori" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbCategory" Width="180" SelectionChanged="Filter_Changed"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                </StackPanel>

                <!-- Arama -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Ürün Ara" FontSize="11" Foreground="#64748B" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid>
                        <TextBox x:Name="TxtSearch" Width="250"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Kod veya Ad ile Ara"
                                 TextChanged="TxtSearch_TextChanged"/>
                        <materialDesign:PackIcon Kind="Magnify" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#94A3B8"/>
                    </Grid>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <materialDesign:Card Grid.Row="1" Margin="16" UniformCornerRadius="10">
            <Grid>
                <DataGrid x:Name="GridHistory" 
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="White"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          materialDesign:DataGridAssist.CellPadding="12,8,12,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Dönem" Binding="{Binding PeriodDisplay}" Width="80"/>
                        <DataGridTextColumn Header="Kategori" Binding="{Binding ExcelFileType}" Width="120"/>
                        <DataGridTextColumn Header="Ürün Kodu" Binding="{Binding ProductCode}" Width="130"/>
                        <DataGridTextColumn Header="Ürün Adı" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Peşin" Binding="{Binding CashPrice, StringFormat={}{0:N2} ₺}" Width="110"/>
                        <DataGridTextColumn Header="30 Gün" Binding="{Binding WholesalePrice30, StringFormat={}{0:N2} ₺}" Width="110"/>
                        <DataGridTextColumn Header="60 Gün" Binding="{Binding WholesalePrice60, StringFormat={}{0:N2} ₺}" Width="110"/>
                        <DataGridTextColumn Header="90 Gün" Binding="{Binding WholesalePrice90, StringFormat={}{0:N2} ₺}" Width="110"/>
                        <DataGridTextColumn Header="120 Gün" Binding="{Binding WholesalePrice120, StringFormat={}{0:N2} ₺}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- No Data Message -->
                <StackPanel x:Name="PnlNoData" VerticalAlignment="Center" Visibility="Collapsed">
                    <materialDesign:PackIcon Kind="DatabaseSearch" Width="64" Height="64" Foreground="#E2E8F0" HorizontalAlignment="Center"/>
                    <TextBlock Text="Bu döneme ait kayıt bulunamadı." Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Footer / Pagination -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <TextBlock x:Name="TxtTotalCount" Text="0 Ürün" VerticalAlignment="Center" Foreground="#64748B" FontWeight="SemiBold"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnPrev" Content="Önceki" Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Height="32" Padding="12,0" Margin="0,0,16,0" Click="BtnPrev_Click"/>
                    
                    <TextBlock x:Name="TxtPageInfo" Text="Sayfa 1 / 1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569"/>
                    
                    <Button x:Name="BtnNext" Content="Sonraki" Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Height="32" Padding="12,0" Margin="16,0,0,0" Click="BtnNext_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid x:Name="OverlayLoading" Grid.RowSpan="3" Background="#AAFFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Width="40" Height="40" Foreground="#E02020" HorizontalAlignment="Center"/>
                <TextBlock Text="Veriler Yükleniyor..." Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#1C2B4A"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
