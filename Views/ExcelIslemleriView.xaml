<UserControl x:Class="ArcelikExcelApp.Views.ExcelIslemleriView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <materialDesign:PackIcon Kind="FileExcel" Width="32" Height="32" Foreground="#4CAF50"/>
            <TextBlock Text="Excel İşlemleri" FontSize="24" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Yükleme Alanı -->
        <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>


                <!-- Kategori Seçimi -->
                <ComboBox x:Name="CmbCategory" Grid.Column="0" Width="170" Margin="0,0,16,0"
                          materialDesign:HintAssist.Hint="Kategori Seçin"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          SelectionChanged="CmbCategory_SelectionChanged"
                          VerticalAlignment="Top">
                    <ComboBoxItem Content="Kea"/>
                    <ComboBoxItem Content="Beyaz Eşya"/>
                    <ComboBoxItem Content="Oliz Kampanya"/>
                </ComboBox>


                <!-- Beyaz Eşya Alt Tipi -->
                <ComboBox x:Name="CmbWhiteGoodsType" Grid.Column="1" Width="170" Margin="0,0,16,0"
                          materialDesign:HintAssist.Hint="Ürün Tipi"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Visibility="Collapsed"
                          VerticalAlignment="Top"/>



                <!-- Oliz Çalışma Sayfası -->
                <ComboBox x:Name="CmbWorksheet" Grid.Column="2" Width="170" Margin="0,0,16,0"
                          materialDesign:HintAssist.Hint="Çalışma Sayfası"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Visibility="Collapsed"
                          VerticalAlignment="Top"/>



                <!-- Dönem ve Seçenekler -->
                <StackPanel Grid.Column="3" Margin="0,0,16,0" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <ComboBox x:Name="CmbPeriodMonth" Width="105" Margin="0,0,8,0"
                                  materialDesign:HintAssist.Hint="Ay"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Ocak" Tag="1"/>
                            <ComboBoxItem Content="Şubat" Tag="2"/>
                            <ComboBoxItem Content="Mart" Tag="3"/>
                            <ComboBoxItem Content="Nisan" Tag="4"/>
                            <ComboBoxItem Content="Mayıs" Tag="5"/>
                            <ComboBoxItem Content="Haziran" Tag="6"/>
                            <ComboBoxItem Content="Temmuz" Tag="7"/>
                            <ComboBoxItem Content="Ağustos" Tag="8"/>
                            <ComboBoxItem Content="Eylül" Tag="9"/>
                            <ComboBoxItem Content="Ekim" Tag="10"/>
                            <ComboBoxItem Content="Kasım" Tag="11"/>
                            <ComboBoxItem Content="Aralık" Tag="12"/>
                        </ComboBox>
                        <ComboBox x:Name="CmbPeriodYear" Width="95"
                                  materialDesign:HintAssist.Hint="Yıl"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkIsHistory" Content="Geçmiş Fiyat Olarak Yükle" Margin="4,8,0,0"
                              Foreground="#6B7280" FontSize="11" FontWeight="Medium"/>
                </StackPanel>


                <!-- Dosya Yükleme Alanı -->
                <Border Grid.Column="4" BorderBrush="#D1D5DB" BorderThickness="2" CornerRadius="8"

                        Background="Transparent" Padding="20" AllowDrop="True"
                        Drop="Border_Drop" Cursor="Hand" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="CloudUpload" Width="48" Height="48" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Dosya Seçmek İçin Tıklayın veya Sürükleyin" Foreground="#6B7280" Margin="0,10,0,0"/>
                        <TextBlock x:Name="TxtSelectedFile" Text="" Foreground="#E02020" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Button x:Name="BtnUpload"
                        Content="Yükle ve İşle"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#E02020" BorderBrush="Transparent" Foreground="White"
                        Width="120" Height="45" Margin="20,0,0,0"
                        Click="BtnUpload_Click" VerticalAlignment="Center" Grid.Column="5"/>


            </Grid>
        </Border>

        <!-- Liste / Önizleme -->
        <materialDesign:Card Grid.Row="2" Margin="0,20,0,0" UniformCornerRadius="12">
            <DataGrid x:Name="GridPreview" AutoGenerateColumns="True" IsReadOnly="True"
                      Background="White" BorderThickness="0" HeadersVisibility="Column"/>
        </materialDesign:Card>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Background="#B2FFFFFF" Grid.RowSpan="3" Panel.ZIndex="99">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True"
                             Width="56" Height="56" Foreground="#E02020" HorizontalAlignment="Center"/>
                <TextBlock Text="Excel İşleniyor..." Margin="0,15,0,0" FontWeight="SemiBold"
                           Foreground="#374151" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Snackbar Notification -->
        <materialDesign:Snackbar x:Name="MainSnackbar" Grid.Row="2"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                                 Panel.ZIndex="100" Margin="20"/>
    </Grid>
</UserControl>
