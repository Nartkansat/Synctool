<UserControl x:Class="Synctool.Views.YeniFiyatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F4F6F8"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ayarlar Paneli -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,16">
            <WrapPanel Orientation="Horizontal">

                <!-- PricePP Kaynağı -->
                <StackPanel Margin="0,0,24,8" VerticalAlignment="Bottom">
                    <TextBlock Text="Baz Fiyat (PricePP)" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbPricePPSource" Width="170"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Fiyat Kaynağı"
                              SelectionChanged="CmbPricePPSource_SelectionChanged">
                        <ComboBoxItem Content="WholesalePrice60" IsSelected="True" Tag="WholesalePrice60"/>
                        <ComboBoxItem Content="WholesalePrice30" Tag="WholesalePrice30"/>
                        <ComboBoxItem Content="WholesalePrice90" Tag="WholesalePrice90"/>
                        <ComboBoxItem Content="WholesalePrice120" Tag="WholesalePrice120"/>
                        <ComboBoxItem Content="CashPrice" Tag="CashPrice"/>
                    </ComboBox>
                </StackPanel>

                <!-- Oliz Kampanya Dosyası -->
                <StackPanel Margin="0,0,24,8" VerticalAlignment="Bottom">
                    <TextBlock Text="Oliz Kampanya Dosyası" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbOlizFile" Width="220"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Dosya Seç"
                              DisplayMemberPath="FileName"
                              SelectedValuePath="Id"/>
                </StackPanel>

                <!-- Kategori Seçimi -->
                <StackPanel Margin="0,0,24,8" VerticalAlignment="Bottom">
                    <TextBlock Text="Ürün Kategorisi" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbCategory" Width="160"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Kategori"
                              SelectionChanged="CmbCategory_SelectionChanged">
                        <ComboBoxItem Content="KEA" IsSelected="True"/>
                        <ComboBoxItem Content="Beyaz Eşya"/>
                        <ComboBoxItem Content="Tümü"/>
                    </ComboBox>
                </StackPanel>

                <!-- Ürün Dosyaları (Çoklu Seçim) -->
                <StackPanel Margin="0,0,24,8" VerticalAlignment="Bottom">
                    <TextBlock Text="Ürün Dosyaları" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <Button x:Name="BtnSelectFiles" Style="{StaticResource MaterialDesignOutlinedButton}" 
                            Width="240" HorizontalContentAlignment="Stretch" Padding="10,0" Height="50" 
                            BorderBrush="#E2E8F0" Foreground="#1A1A24" Click="BtnSelectFiles_Click">
                        <Grid>
                            <TextBlock x:Name="TxtSelectedFilesCount" Text="Tüm Dosyalar" VerticalAlignment="Center"/>
                            <materialDesign:PackIcon Kind="ChevronDown" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                    
                    <Popup x:Name="PopupFileSelection" AllowsTransparency="True" StaysOpen="False" 
                           Placement="Bottom" PlacementTarget="{Binding ElementName=BtnSelectFiles}"
                           PopupAnimation="Fade">
                        <materialDesign:Card Width="320" MaxHeight="450" UniformCornerRadius="12" Background="White" 
                                           materialDesign:ElevationAssist.Elevation="Dp12" Margin="5" >
                            <Border Padding="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBox x:Name="TxtSearchProductFiles" 
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Dosya ara..."
                                             Margin="0,0,0,10"
                                             TextChanged="TxtSearchProductFiles_TextChanged"/>

                                    <CheckBox x:Name="ChkSelectAllFiles" Grid.Row="1" Content="Tümünü Seç / Kaldır" 
                                              Margin="0,0,0,10" FontWeight="Bold"
                                              IsChecked="True" Click="ChkSelectAllFiles_Click"/>
                                    
                                    <ListBox x:Name="LstProductFiles" Grid.Row="2" MaxHeight="250"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             BorderThickness="0,1" BorderBrush="#F1F5F9">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding FileName}" 
                                                          IsChecked="{Binding IsSelected}" 
                                                          Margin="0,2"
                                                          Checked="FileCheckBox_Changed" Unchecked="FileCheckBox_Changed"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Button Grid.Row="3" Content="Seçimi Uygula" 
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Margin="0,10,0,0" Click="BtnApplySelection_Click"/>
                                </Grid>
                            </Border>
                        </materialDesign:Card>
                    </Popup>
                </StackPanel>

                <!-- Kart Markup % -->
                <StackPanel Margin="0,0,24,8" VerticalAlignment="Bottom">
                    <TextBlock Text="Kart Fiyatı Markup (%)" FontSize="11" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtCardMarkup" Width="100"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Örn: 10"
                             Text="10"
                             TextAlignment="Center"/>
                </StackPanel>

                <!-- Hesapla Butonu -->
                <StackPanel VerticalAlignment="Bottom" Margin="0,0,12,8">
                    <Button x:Name="BtnCalculate"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#E02020" BorderBrush="Transparent" Foreground="White"
                            Height="40" Padding="16,0"
                            Click="BtnCalculate_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlayCircle" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Hesapla" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <!-- Kaydet Butonu -->
                <StackPanel VerticalAlignment="Bottom" Margin="0,0,12,8">
                    <Button x:Name="BtnSave"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#16A34A" BorderBrush="Transparent" Foreground="White"
                            Height="40" Padding="16,0"
                            IsEnabled="False"
                            Click="BtnSave_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="DB'ye Kaydet" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

                <!-- Excel Export Butonu -->
                <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,8">
                    <Button x:Name="BtnExport"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="#1D6F42" BorderBrush="#1D6F42"
                            Height="40" Padding="16,0"
                            IsEnabled="False"
                            Click="BtnExport_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MicrosoftExcel" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Excel'e Aktar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>

            </WrapPanel>
        </Border>

        <!-- Sonuç Tablosu -->
        <materialDesign:Card Grid.Row="1" Margin="16,16,16,8" UniformCornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tablo Başlığı + Özet -->
                <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <materialDesign:PackIcon Kind="TableLarge" VerticalAlignment="Center" Foreground="#64748B" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtResultSummary" Text="Hesaplama sonuçları burada görünecek"
                                       FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Background="#FEF2F2" CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Kampanyalı: " FontSize="11" Foreground="#DC2626"/>
                                    <TextBlock x:Name="TxtCampaignCount" Text="0" FontSize="11" FontWeight="Bold" Foreground="#DC2626"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F0FDF4" CornerRadius="6" Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Kampanyasız: " FontSize="11" Foreground="#16A34A"/>
                                    <TextBlock x:Name="TxtNoCampaignCount" Text="0" FontSize="11" FontWeight="Bold" Foreground="#16A34A"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <DataGrid x:Name="GridResults" Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="White"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F5F9"
                          CanUserSortColumns="True"
                          materialDesign:DataGridAssist.CellPadding="12,8,12,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="100"/>
                        <DataGridTextColumn Header="Ürün Kodu" Binding="{Binding ProductCode}" Width="130"/>
                        <DataGridTextColumn Header="Ürün Adı" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="PricePP" Binding="{Binding PricePP, StringFormat={}{0:N2} ₺}" Width="100"/>
                        <DataGridTextColumn Header="Kampanya İnd." Binding="{Binding PriceConversion, StringFormat={}{0:N2} ₺}" Width="110"/>
                        <DataGridTextColumn Header="Maliyet (Net)" Binding="{Binding PurchasePrice, StringFormat={}{0:N2} ₺}" Width="110"/>
                        <DataGridTextColumn Header="Kart Fiyatı" Binding="{Binding CardPurchasePrice, StringFormat={}{0:N2} ₺}" Width="110"/>
                        <DataGridTextColumn Header="Markup %" Binding="{Binding CardMarkupPercent, StringFormat={}{0:N0}%}" Width="80"/>
                        <DataGridTextColumn Header="Kampanya?" Binding="{Binding HasCampaignDisplay}" Width="90"/>
                        <DataGridTextColumn Header="PricePP Kaynağı" Binding="{Binding PricePPSource}" Width="120"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCampaign}" Value="True">
                                    <Setter Property="Background" Value="#FFF5F5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="16,6">
            <TextBlock x:Name="TxtStatus" Text="Hazır — Hesaplamak için yukarıdaki ayarları yapıp 'Hesapla' butonuna tıklayın."
                       FontSize="11" Foreground="#94A3B8"/>
        </Border>
    </Grid>
</UserControl>
