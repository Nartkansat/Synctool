<UserControl x:Class="Synctool.Views.KampanyaBilgiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#F8FAFC">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="16" Padding="16,12" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.04" ShadowDepth="2" Color="#64748B"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left Title & Icon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="250">
                        <TextBox x:Name="TxtSearch"
              Style="{StaticResource MaterialDesignOutlinedTextBox}"
              materialDesign:HintAssist.Hint="Ürün Kodu veya Adı Ara..."
              materialDesign:TextFieldAssist.UnderlineBrush="#0891B2"
              CaretBrush="#0891B2"
              Height="36"
              Padding="10,6"
              VerticalContentAlignment="Center"
              TextChanged="TxtSearch_TextChanged"
              KeyDown="TxtSearch_KeyDown"/>
                        <materialDesign:PackIcon Kind="Magnify" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#94A3B8"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="8,0,0,0" x:Name="PnlSearchNav" Visibility="Collapsed">
                        <Button x:Name="BtnPrevMatch" Style="{StaticResource MaterialDesignIconButton}" 
              Width="32" Height="32" Click="BtnPrevMatch_Click" ToolTip="Önceki Sonuç">
                            <materialDesign:PackIcon Kind="ChevronLeft" Foreground="#64748B" Width="20" Height="20"/>
                        </Button>
                        <TextBlock x:Name="TxtMatchCount" Text="0 / 0" VerticalAlignment="Center" Margin="4,0" FontWeight="SemiBold" Foreground="#64748B" FontSize="13"/>
                        <Button x:Name="BtnNextMatch" Style="{StaticResource MaterialDesignIconButton}" 
              Width="32" Height="32" Click="BtnNextMatch_Click" ToolTip="Sonraki Sonuç">
                            <materialDesign:PackIcon Kind="ChevronRight" Foreground="#64748B" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

             
                <!-- Right Refresh -->
                <Button Grid.Column="2" x:Name="BtnRefresh" Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="#0891B2" Click="BtnRefresh_Click" Height="36" Padding="12,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" VerticalAlignment="Center"/>
                        <TextBlock Text="YENİLE" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="SvCampaigns" VerticalScrollBarVisibility="Auto" ScrollChanged="SvCampaigns_ScrollChanged">
                <StackPanel>
                    <ItemsControl x:Name="IcCampaigns">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="20" Margin="0,0,0,24" Padding="28">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="30" Opacity="0.05" ShadowDepth="8" Color="#64748B"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Top Row: Category & Date -->
                                    <Grid Grid.Row="0" Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#F1F5F9" CornerRadius="8" Padding="12,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Tag" Width="14" Height="14" Foreground="#475569" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Category}" Margin="6,0,0,0" FontSize="12" FontWeight="Bold" Foreground="#475569"/>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat=\{0:dd MMMM yyyy HH:mm\}}" 
                                                       Margin="16,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="#94A3B8"/>
                                        </StackPanel>

                                        <materialDesign:PackIcon Grid.Column="1" Kind="CheckCircle" Foreground="#10B981" Width="24" Height="24"/>
                                    </Grid>

                                    <!-- Description -->
                                    <TextBlock Grid.Row="1" Text="{Binding Description}" 
                                               FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" 
                                               TextWrapping="Wrap" LineHeight="26" Margin="0,0,0,20"/>

                                    <Separator Grid.Row="2" Background="#F1F5F9" Margin="0,0,0,20"/>

                                    <!-- Products Header -->
                                    <StackPanel Grid.Row="3">
                                        <TextBlock Text="KAMPANYALI ÜRÜNLER" FontSize="11" FontWeight="Black" Foreground="#94A3B8" Margin="0,0,0,16"/>
                                        
                                        <ItemsControl ItemsSource="{Binding VisibleProducts}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Tag="ProductCard" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" 
                                                            CornerRadius="14" Margin="0,0,12,12" Padding="16,12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <Border Width="40" Height="40" Background="White" CornerRadius="10" BorderBrush="#F1F5F9" BorderThickness="1">
                                                                <materialDesign:PackIcon Kind="ShoppingOutline" Width="20" Height="20" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ProductName}" FontWeight="Bold" Foreground="#1E293B" FontSize="14" TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.ToolTip>
                                                                        <TextBlock Text="{Binding ProductName}" MaxWidth="400" TextWrapping="Wrap"/>
                                                                    </TextBlock.ToolTip>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding ProductCode}" FontSize="12" Foreground="#94A3B8" FontWeight="Medium" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Expand/Collapse Button -->
                                        <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                Click="BtnToggleExpand_Click"
                                                HorizontalAlignment="Center"
                                                Margin="0,8,0,0"
                                                Foreground="#0891B2"
                                                Visibility="{Binding HasMoreProducts, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="{Binding ExpandButtonIcon}" Width="18" Height="18" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ExpandButtonText}" Margin="6,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Paging Loading -->
                    <Border x:Name="PagingLoading" Visibility="Collapsed" Margin="0,0,0,24">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Width="32" Height="32" Foreground="#0891B2"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Loading Overlay -->
            <Border x:Name="LoadingOverlay" Background="#99FFFFFF" Visibility="Collapsed" CornerRadius="20">
                <StackPanel VerticalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" Width="48" Height="48" Foreground="#0891B2"/>
                    <TextBlock Text="Kampanyalar Yükleniyor..." Margin="0,16,0,0" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#0891B2"/>
                </StackPanel>
            </Border>

            <!-- Empty State -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center" Visibility="Collapsed">
                <materialDesign:PackIcon Kind="TagOffOutline" Width="80" Height="80" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                <TextBlock Text="Henüz Hiç Kampanya Tanımlanmamış" Margin="0,24,0,0" FontSize="20" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center"/>
                <TextBlock Text="Manuel kampanyalar eklendiğinde burada görünecektir." Margin="0,8,0,0" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <materialDesign:Snackbar x:Name="MainSnackbar" Grid.RowSpan="2" MessageQueue="{materialDesign:MessageQueue}"/>
    </Grid>
</UserControl>
